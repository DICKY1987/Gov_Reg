{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/relationship_index.schema.json",
  "title": "Relationship Index Schema",
  "description": "Schema for the autonomous relationship index built from doc_id-tagged repository files. Captures code-level relationships (imports, schema references, dot-sourcing) separate from SSOT governance relationships.",
  "type": "object",
  "required": [
    "meta",
    "nodes",
    "edges",
    "statistics"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "description": "Metadata about the relationship index generation",
      "required": [
        "doc_id",
        "generated_at",
        "generator_version",
        "total_nodes",
        "total_edges",
        "source_registry"
      ],
      "properties": {
        "doc_id": {
          "type": "string",
          "description": "Document ID for this relationship index artifact",
          "pattern": "^DOC-.+-.+-[A-Z0-9]{3,}$"
        },
        "generated_at": {
          "type": "string",
          "description": "ISO 8601 timestamp of index generation",
          "format": "date-time"
        },
        "generator_version": {
          "type": "string",
          "description": "Version of the relationship index generator",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "total_nodes": {
          "type": "integer",
          "description": "Total number of nodes (files) in the index",
          "minimum": 0
        },
        "total_edges": {
          "type": "integer",
          "description": "Total number of edges (relationships) in the index",
          "minimum": 0
        },
        "source_registry": {
          "type": "string",
          "description": "Path to the doc_id registry used as input"
        },
        "run_id": {
          "type": "string",
          "description": "Optional run ID for observability tracing"
        },
        "trace_id": {
          "type": "string",
          "description": "Optional trace ID for observability correlation"
        }
      }
    },
    "nodes": {
      "type": "array",
      "description": "Array of file nodes extracted from the doc_id registry",
      "items": {
        "type": "object",
        "required": [
          "doc_id",
          "path",
          "file_type",
          "status"
        ],
        "properties": {
          "doc_id": {
            "type": "string",
            "description": "Unique document ID for this file",
            "pattern": "^DOC-.+-.+-[A-Z0-9]{3,}$"
          },
          "path": {
            "type": "string",
            "description": "Relative path to the file from repository root"
          },
          "file_type": {
            "type": "string",
            "description": "File extension or type (py, json, ps1, etc.)"
          },
          "status": {
            "type": "string",
            "description": "Status of the file node",
            "enum": [
              "active",
              "deprecated",
              "unknown"
            ]
          },
          "last_modified": {
            "type": "string",
            "description": "ISO 8601 timestamp of last file modification",
            "format": "date-time"
          }
        }
      }
    },
    "edges": {
      "type": "array",
      "description": "Array of relationship edges between file nodes",
      "items": {
        "type": "object",
        "required": [
          "rel_id",
          "source",
          "target",
          "type",
          "confidence",
          "evidence",
          "analyzer_id",
          "last_verified"
        ],
        "properties": {
          "rel_id": {
            "type": "string",
            "description": "Stable relationship ID: REL-<SHA256(source:target:type)[:16]>",
            "pattern": "^REL-[a-f0-9]{16}$"
          },
          "source": {
            "type": "string",
            "description": "Source file doc_id (the file that creates the relationship)",
            "pattern": "^DOC-.+-.+-[A-Z0-9]{3,}$"
          },
          "target": {
            "type": "string",
            "description": "Target file doc_id (the file being referenced/imported)"
          },
          "type": {
            "type": "string",
            "description": "Type of relationship edge",
            "enum": [
              "imports",
              "references_schema",
              "dot_sources",
              "documents",
              "references_yaml",
              "tests"
            ]
          },
          "confidence": {
            "type": "number",
            "description": "Confidence level: 1.0 = high (AST/schema), 0.8 = medium (regex), 0.0 = broken",
            "enum": [
              0.0,
              0.8,
              0.9,
              1.0
            ]
          },
          "evidence": {
            "type": "object",
            "description": "Evidence supporting this relationship",
            "required": [
              "location",
              "snippet",
              "extraction_method"
            ],
            "properties": {
              "location": {
                "type": "string",
                "description": "Location in source file (e.g., 'file.py:15' or 'file.json:$.schemas[0].$ref')"
              },
              "snippet": {
                "type": "string",
                "description": "Code snippet showing the relationship (e.g., 'import module' or '$ref: ./schema.json')"
              },
              "extraction_method": {
                "type": "string",
                "description": "Method used to extract this relationship",
                "enum": [
                  "python_ast_import",
                  "json_schema_ref",
                  "powershell_ast",
                  "markdown_inline_link",
                  "markdown_reference_link",
                  "yaml_include",
                  "test_naming_convention",
                  "test_import_analysis",
                  "test_bdd_reference"
                ]
              }
            }
          },
          "analyzer_id": {
            "type": "string",
            "description": "ID of the analyzer that discovered this edge",
            "enum": [
              "python_import_analyzer",
              "schema_reference_analyzer",
              "power_shell_import_analyzer",
              "markdown_link_analyzer",
              "yaml_reference_analyzer",
              "test_link_analyzer"
            ]
          },
          "last_verified": {
            "type": "string",
            "description": "ISO 8601 timestamp when this edge was last verified",
            "format": "date-time"
          },
          "flags": {
            "type": "array",
            "description": "Optional flags indicating edge status or warnings",
            "items": {
              "type": "string",
              "enum": [
                "target_missing",
                "ambiguous_target",
                "external_dependency"
              ]
            },
            "default": []
          }
        }
      }
    },
    "statistics": {
      "type": "object",
      "description": "Aggregated statistics about the relationship index",
      "required": [
        "edge_types",
        "confidence_distribution",
        "analyzer_coverage"
      ],
      "properties": {
        "edge_types": {
          "type": "object",
          "description": "Count of edges by type",
          "properties": {
            "imports": {
              "type": "integer",
              "minimum": 0
            },
            "references_schema": {
              "type": "integer",
              "minimum": 0
            },
            "dot_sources": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "confidence_distribution": {
          "type": "object",
          "description": "Count of edges by confidence level",
          "properties": {
            "high": {
              "type": "integer",
              "description": "Number of edges with confidence = 1.0",
              "minimum": 0
            },
            "broken": {
              "type": "integer",
              "description": "Number of edges with confidence = 0.0",
              "minimum": 0
            }
          }
        },
        "analyzer_coverage": {
          "type": "object",
          "description": "Count of edges discovered by each analyzer",
          "properties": {
            "python_import_analyzer": {
              "type": "integer",
              "minimum": 0
            },
            "schema_reference_analyzer": {
              "type": "integer",
              "minimum": 0
            },
            "powershell_import_analyzer": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "file_type_coverage": {
          "type": "object",
          "description": "Count of nodes by file type",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  },
  "doc_id": "DOC-CONFIG-RELATIONSHIP-INDEX-SCHEMA-994"
}
