# SUB_GUI Environment Configuration
# Copy this file to .env and customize for your environment

# State Files Directory
# Location of PHASE_5_EXECUTION state files (.state/*.json)
STATE_DIR=.state

# Alternative: Absolute path to state directory
# STATE_DIR=C:/Users/yourname/ALL_AI/PHASE_5_EXECUTION/.state

# UI Refresh Interval (seconds)
# How often to check for state file updates
# STATE_REFRESH_INTERVAL=2

# Run ID (optional)
# Specific run ID to monitor. If empty, uses latest from state files
# RUN_ID=

# Mock Data Mode (development only)
# Set to "true" to use mock data instead of real state files
# USE_MOCK_DATA=false
