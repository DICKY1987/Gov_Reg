{
  "document": "reserved_id_namespaces",
  "purpose": "Phase B.0 reserved semantic ID families for the v3.2 to v3.3 governance migration",
  "source_runbook": "greedy-stirring-tower.md",
  "validation_phase": "A.3",
  "namespaces": [
    {
      "name": "config_gate_id",
      "pattern": "^GATE-CFG-\\d{3}$",
      "must_be_non_empty_after_phase_b": true
    },
    {
      "name": "pattern_id",
      "pattern": "^PAT-[A-Z0-9-]+$",
      "must_be_non_empty_after_phase_b": true
    },
    {
      "name": "executor_id",
      "pattern": "^EXEC-[A-Z0-9-]+$",
      "must_be_non_empty_after_phase_b": true
    },
    {
      "name": "component_id",
      "pattern": "^COMP-L\\d-\\d{2}$",
      "must_be_non_empty_after_phase_b": true
    }
  ]
}
