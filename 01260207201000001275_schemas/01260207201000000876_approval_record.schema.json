{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Approval Record Schema",
  "description": "Schema for governance approval records in stakeholder approval framework",
  "type": "object",
  "required": ["approval_id", "timestamp", "change_id", "approval_level", "approvers", "decision"],
  "properties": {
    "approval_id": {
      "type": "string",
      "pattern": "^APPR-[0-9]{8}-[0-9]{4}$",
      "description": "Unique approval identifier (format: APPR-YYYYMMDD-NNNN)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 UTC timestamp of approval decision"
    },
    "change_id": {
      "type": "string",
      "description": "Reference to the change being approved"
    },
    "approval_level": {
      "enum": ["L1_ROUTINE", "L2_SIGNIFICANT", "L3_CRITICAL"],
      "description": "Required approval level based on impact assessment"
    },
    "approvers": {
      "type": "array",
      "minItems": 1,
      "maxItems": 7,
      "items": {
        "type": "object",
        "required": ["name", "role", "vote"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Full name of approver"
          },
          "role": {
            "enum": [
              "Technical Lead",
              "Operations Manager",
              "Engineering Manager",
              "Product Owner",
              "Security Lead",
              "Compliance Officer",
              "CTO"
            ],
            "description": "Organizational role of approver"
          },
          "vote": {
            "enum": ["approve", "reject", "abstain"],
            "description": "Approval vote cast by this approver"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 UTC timestamp when vote was cast"
          },
          "comment": {
            "type": "string",
            "description": "Optional comment from approver"
          }
        }
      }
    },
    "decision": {
      "enum": ["APPROVED", "REJECTED", "DEFERRED"],
      "description": "Final approval decision"
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "References to supporting evidence artifacts"
    },
    "note": {
      "type": "string",
      "description": "Optional additional notes about the approval"
    }
  }
}
