{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "spec_id": "NPP_LOCAL_PLANNING_MCP_TOOL_SSOT",
  "spec_version": "1.0.0",
  "generated_by": "chatgpt",
  "purpose": "Single Source of Truth (SSOT) tool definitions for NPP Local Planning MCP (stdio). Defines 5 deterministic planning tools with strict input/output schemas, defect codes, and default evidence paths.",
  "global_invariants": {
    "transport": "stdio",
    "network_required": false,
    "repo_root_confinement": true,
    "determinism": "same_input_same_output_except_timestamps",
    "mutation_policy": "read_only_except_evidence_and_emitted_artifacts",
    "evidence_required": true
  },
  "shared": {
    "defs": {
      "RunContext": {
        "type": "object",
        "required": ["repo_root", "run_id", "invoker"],
        "additionalProperties": false,
        "properties": {
          "repo_root": {
            "type": "string",
            "minLength": 1,
            "description": "Absolute or relative path to the repository root. All paths must resolve under this root."
          },
          "run_id": {
            "type": "string",
            "pattern": "^RUN-[A-Z0-9_-]{6,64}$",
            "description": "Correlation ID for tool execution and evidence bundle."
          },
          "invoker": {
            "type": "string",
            "enum": ["human", "ai", "ci"],
            "description": "Who initiated the tool call."
          },
          "plan_id": {
            "type": "string",
            "pattern": "^PLAN-[A-Z0-9]{8,16}$",
            "description": "Optional plan identifier for correlation."
          },
          "phase_id": {
            "type": "string",
            "pattern": "^PH-\\d{2,4}$",
            "description": "Optional phase identifier for correlation."
          },
          "step_id": {
            "type": "string",
            "pattern": "^S\\d{3}$",
            "description": "Optional step identifier for correlation."
          }
        }
      },
      "Defect": {
        "type": "object",
        "required": ["severity", "code", "location", "message"],
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["info", "low", "medium", "high", "critical"]
          },
          "code": {
            "type": "string",
            "pattern": "^[A-Z0-9_]{3,64}$"
          },
          "location": {
            "type": "string",
            "minLength": 1,
            "description": "JSONPointer-like location or file path / logical location."
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "why_it_matters": {
            "type": "string"
          },
          "remediation_hint": {
            "type": "string"
          }
        }
      },
      "ToolResultEnvelope": {
        "type": "object",
        "required": ["tool", "tool_version", "status", "exit_code", "run_id", "evidence_paths"],
        "additionalProperties": false,
        "properties": {
          "tool": {
            "type": "string",
            "minLength": 1
          },
          "tool_version": {
            "type": "string",
            "pattern": "^\\d+\\.\\d+\\.\\d+$"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail", "error", "not_automatable"]
          },
          "exit_code": {
            "type": "integer",
            "description": "0 indicates success (pass). Non-zero indicates fail/error as defined by tool."
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          },
          "summary": {
            "type": "string"
          },
          "evidence_paths": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "artifacts_emitted": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "default": []
          },
          "defects": {
            "type": "array",
            "items": { "$ref": "#/shared/defs/Defect" },
            "default": []
          },
          "hashes": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "default": {}
          },
          "metrics": {
            "type": "object",
            "additionalProperties": { "type": "number" },
            "default": {}
          }
        }
      },
      "ServerLevelDefectCodes": {
        "type": "array",
        "items": { "type": "string" },
        "default": [
          "REPO_ROOT_VIOLATION",
          "INPUT_FILE_NOT_FOUND",
          "EXEC_BINDING_MISSING",
          "NOT_AUTOMATABLE",
          "UNSAFE_OPERATION_BLOCKED",
          "INVALID_INPUT_SCHEMA",
          "INTERNAL_ERROR",
          "TIMEOUT"
        ]
      }
    }
  },
  "tools": [
    {
      "tool": "plan.validate_structure",
      "tool_version": "1.0.0",
      "description": "Validate plan structure (required sections, nesting, ID formats). Writes evidence JSON and returns pass/fail with normalized defects.",
      "default_evidence_path_template": ".state/evidence/mcp/{run_id}/plan_validate_structure.json",
      "input_schema": {
        "type": "object",
        "required": ["context", "plan_path"],
        "additionalProperties": false,
        "properties": {
          "context": { "$ref": "#/shared/defs/RunContext" },
          "plan_path": {
            "type": "string",
            "minLength": 1,
            "description": "Path to the plan JSON (must resolve under repo_root)."
          },
          "write_evidence": {
            "type": "boolean",
            "default": true
          },
          "evidence_path": {
            "type": "string",
            "minLength": 1,
            "default": ".state/evidence/mcp/{run_id}/plan_validate_structure.json"
          },
          "timeout_s": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600,
            "default": 300
          }
        }
      },
      "output_schema": { "$ref": "#/shared/defs/ToolResultEnvelope" },
      "defect_codes_minimum": [
        "MISSING_SECTION",
        "MISSING_FIELD",
        "INVALID_TYPE",
        "INVALID_JSON",
        "INVALID_ID_FORMAT",
        "LOAD_ERROR",
        "REPO_ROOT_VIOLATION",
        "INPUT_FILE_NOT_FOUND",
        "TIMEOUT",
        "INTERNAL_ERROR"
      ],
      "evidence_requirements": {
        "must_write_evidence_if_write_evidence_true": true,
        "evidence_json_minimum_fields": [
          "tool",
          "tool_version",
          "run_id",
          "status",
          "exit_code",
          "input",
          "defects",
          "hashes",
          "timestamps"
        ]
      }
    },
    {
      "tool": "plan.validate_step_contracts",
      "tool_version": "1.0.0",
      "description": "Validate step-level contract completeness and consistency (required fields, step_id uniqueness/patterns, artifact refs, command fields). Writes evidence JSON and returns defects.",
      "default_evidence_path_template": ".state/evidence/mcp/{run_id}/plan_validate_step_contracts.json",
      "input_schema": {
        "type": "object",
        "required": ["context", "plan_path"],
        "additionalProperties": false,
        "properties": {
          "context": { "$ref": "#/shared/defs/RunContext" },
          "plan_path": {
            "type": "string",
            "minLength": 1
          },
          "phase_filter": {
            "type": "array",
            "items": { "type": "string", "pattern": "^PH-\\d{2,4}$" },
            "default": [],
            "description": "Optional list of phase_ids to validate. Empty means validate all."
          },
          "write_evidence": {
            "type": "boolean",
            "default": true
          },
          "evidence_path": {
            "type": "string",
            "minLength": 1,
            "default": ".state/evidence/mcp/{run_id}/plan_validate_step_contracts.json"
          },
          "timeout_s": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600,
            "default": 300
          }
        }
      },
      "output_schema": { "$ref": "#/shared/defs/ToolResultEnvelope" },
      "defect_codes_minimum": [
        "NO_PHASES_DEFINED",
        "PHASE_HAS_NO_STEPS",
        "STEP_MISSING_REQUIRED_FIELD",
        "STEP_ID_NOT_UNIQUE",
        "STEP_ID_PATTERN_INVALID",
        "ARTIFACT_REF_INVALID",
        "COMMAND_INVALID",
        "PRECONDITIONS_MISSING",
        "POSTCONDITIONS_MISSING",
        "ROLLBACK_INVALID",
        "IDEMPOTENCY_INVALID",
        "REPO_ROOT_VIOLATION",
        "INPUT_FILE_NOT_FOUND",
        "TIMEOUT",
        "INTERNAL_ERROR"
      ],
      "evidence_requirements": {
        "must_write_evidence_if_write_evidence_true": true,
        "evidence_json_minimum_fields": [
          "tool",
          "tool_version",
          "run_id",
          "status",
          "exit_code",
          "input",
          "defects",
          "hashes",
          "timestamps"
        ]
      }
    },
    {
      "tool": "plan.validate_ssot",
      "tool_version": "1.0.0",
      "description": "Validate Single Source of Truth (SSOT) inside the plan (duplicate facts, contradictions). Writes evidence JSON and returns defects.",
      "default_evidence_path_template": ".state/evidence/mcp/{run_id}/plan_validate_ssot.json",
      "input_schema": {
        "type": "object",
        "required": ["context", "plan_path"],
        "additionalProperties": false,
        "properties": {
          "context": { "$ref": "#/shared/defs/RunContext" },
          "plan_path": {
            "type": "string",
            "minLength": 1
          },
          "ignore_common_paths": {
            "type": "array",
            "items": { "type": "string" },
            "default": [".", "..", "/", "scripts", "schemas", ".state"],
            "description": "Paths that are considered common and may be ignored for duplication warnings."
          },
          "write_evidence": {
            "type": "boolean",
            "default": true
          },
          "evidence_path": {
            "type": "string",
            "minLength": 1,
            "default": ".state/evidence/mcp/{run_id}/plan_validate_ssot.json"
          },
          "timeout_s": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600,
            "default": 300
          }
        }
      },
      "output_schema": { "$ref": "#/shared/defs/ToolResultEnvelope" },
      "defect_codes_minimum": [
        "SSOT_MISSING_PHASES",
        "SSOT_DUPLICATE_PATH_FACT",
        "SSOT_DUPLICATE_VERSION_FACT",
        "SSOT_DUPLICATE_CONFIG_FACT",
        "SSOT_CONTRADICTION",
        "REPO_ROOT_VIOLATION",
        "INPUT_FILE_NOT_FOUND",
        "TIMEOUT",
        "INTERNAL_ERROR"
      ],
      "evidence_requirements": {
        "must_write_evidence_if_write_evidence_true": true,
        "evidence_json_minimum_fields": [
          "tool",
          "tool_version",
          "run_id",
          "status",
          "exit_code",
          "input",
          "defects",
          "hashes",
          "timestamps"
        ]
      }
    },
    {
      "tool": "registry.snapshot_query",
      "tool_version": "1.0.0",
      "description": "Produce an immutable, point-in-time registry snapshot artifact for planning. Read-only against registry; writes snapshot + evidence; returns snapshot hash.",
      "default_evidence_path_template": ".state/evidence/mcp/{run_id}/registry_snapshot_query.json",
      "input_schema": {
        "type": "object",
        "required": ["context", "registry_path", "fields", "output_path"],
        "additionalProperties": false,
        "properties": {
          "context": { "$ref": "#/shared/defs/RunContext" },
          "registry_path": {
            "type": "string",
            "minLength": 1,
            "description": "Path to canonical registry (must resolve under repo_root unless you explicitly allow an external registry root in your server config)."
          },
          "filter": {
            "type": "object",
            "additionalProperties": { "type": "string" },
            "default": {},
            "description": "Key/value filter terms applied to registry query (implementation-defined)."
          },
          "fields": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 },
            "description": "Field names to include in snapshot records."
          },
          "output_path": {
            "type": "string",
            "minLength": 1,
            "description": "Where to write the snapshot JSON artifact (under repo_root)."
          },
          "hash_algo": {
            "type": "string",
            "enum": ["sha256"],
            "default": "sha256"
          },
          "write_evidence": {
            "type": "boolean",
            "default": true
          },
          "evidence_path": {
            "type": "string",
            "minLength": 1,
            "default": ".state/evidence/mcp/{run_id}/registry_snapshot_query.json"
          },
          "timeout_s": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600,
            "default": 300
          }
        }
      },
      "output_schema": { "$ref": "#/shared/defs/ToolResultEnvelope" },
      "defect_codes_minimum": [
        "REGISTRY_QUERY_NOT_IMPLEMENTED",
        "REGISTRY_NOT_FOUND",
        "REGISTRY_INVALID_FORMAT",
        "SNAPSHOT_WRITE_FAILED",
        "REPO_ROOT_VIOLATION",
        "INPUT_FILE_NOT_FOUND",
        "TIMEOUT",
        "INTERNAL_ERROR"
      ],
      "default_artifacts_emitted": [
        "{output_path}"
      ],
      "snapshot_output_contract": {
        "type": "object",
        "required": ["snapshot_id", "created_at", "registry_path", "filters_applied", "fields", "records", "snapshot_hash"],
        "additionalProperties": false,
        "properties": {
          "snapshot_id": { "type": "string", "pattern": "^SNAP-[A-Z0-9_-]{6,64}$" },
          "created_at": { "type": "string", "format": "date-time" },
          "registry_path": { "type": "string" },
          "filters_applied": { "type": "object", "additionalProperties": { "type": "string" } },
          "fields": { "type": "array", "items": { "type": "string" } },
          "records": { "type": "array", "items": { "type": "object" } },
          "snapshot_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      },
      "evidence_requirements": {
        "must_write_evidence_if_write_evidence_true": true,
        "evidence_json_minimum_fields": [
          "tool",
          "tool_version",
          "run_id",
          "status",
          "exit_code",
          "input",
          "defects",
          "hashes",
          "timestamps"
        ]
      }
    },
    {
      "tool": "planning.extract_file_mutation_set",
      "tool_version": "1.0.0",
      "description": "Emit a proposed Planning File Mutation Set (PFMS) from a plan (created/modified/deleted/moved files). Does not apply mutations; writes PFMS artifact + evidence.",
      "default_evidence_path_template": ".state/evidence/mcp/{run_id}/planning_extract_file_mutation_set.json",
      "input_schema": {
        "type": "object",
        "required": ["context", "plan_path", "mutation_set_path"],
        "additionalProperties": false,
        "properties": {
          "context": { "$ref": "#/shared/defs/RunContext" },
          "plan_path": { "type": "string", "minLength": 1 },
          "mutation_set_path": {
            "type": "string",
            "minLength": 1,
            "description": "Where to write PFMS JSON artifact (under repo_root)."
          },
          "mode": {
            "type": "string",
            "enum": ["proposed"],
            "default": "proposed"
          },
          "hash_algo": {
            "type": "string",
            "enum": ["sha256"],
            "default": "sha256"
          },
          "write_evidence": { "type": "boolean", "default": true },
          "evidence_path": {
            "type": "string",
            "minLength": 1,
            "default": ".state/evidence/mcp/{run_id}/planning_extract_file_mutation_set.json"
          },
          "timeout_s": {
            "type": "integer",
            "minimum": 1,
            "maximum": 3600,
            "default": 300
          }
        }
      },
      "output_schema": { "$ref": "#/shared/defs/ToolResultEnvelope" },
      "defect_codes_minimum": [
        "PFMS_EXTRACTOR_NOT_IMPLEMENTED",
        "PLAN_NOT_FOUND",
        "PLAN_INVALID_JSON",
        "PFMS_WRITE_FAILED",
        "REPO_ROOT_VIOLATION",
        "UNSAFE_OPERATION_BLOCKED",
        "TIMEOUT",
        "INTERNAL_ERROR"
      ],
      "default_artifacts_emitted": [
        "{mutation_set_path}"
      ],
      "pfms_output_contract": {
        "type": "object",
        "required": ["pfms_id", "created_at", "status", "source_plan", "mutations", "provenance", "pfms_hash"],
        "additionalProperties": false,
        "properties": {
          "pfms_id": { "type": "string", "pattern": "^PFMS-[A-Z0-9_-]{6,64}$" },
          "created_at": { "type": "string", "format": "date-time" },
          "status": { "type": "string", "enum": ["proposed"] },
          "source_plan": {
            "type": "object",
            "required": ["plan_path", "plan_sha256"],
            "additionalProperties": false,
            "properties": {
              "plan_path": { "type": "string" },
              "plan_sha256": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
            }
          },
          "mutations": {
            "type": "object",
            "required": ["created_files", "modified_files", "deleted_files", "moved_files"],
            "additionalProperties": false,
            "properties": {
              "created_files": { "type": "array", "items": { "$ref": "#/$defs/MutationRecord" } },
              "modified_files": { "type": "array", "items": { "$ref": "#/$defs/MutationRecord" } },
              "deleted_files": { "type": "array", "items": { "$ref": "#/$defs/MutationRecord" } },
              "moved_files": { "type": "array", "items": { "$ref": "#/$defs/MoveRecord" } }
            }
          },
          "provenance": {
            "type": "object",
            "required": ["run_id", "tool", "tool_version", "evidence_paths"],
            "additionalProperties": false,
            "properties": {
              "run_id": { "type": "string" },
              "tool": { "type": "string" },
              "tool_version": { "type": "string" },
              "evidence_paths": { "type": "array", "items": { "type": "string" }, "minItems": 1 }
            }
          },
          "pfms_hash": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" }
        }
      },
      "evidence_requirements": {
        "must_write_evidence_if_write_evidence_true": true,
        "evidence_json_minimum_fields": [
          "tool",
          "tool_version",
          "run_id",
          "status",
          "exit_code",
          "input",
          "defects",
          "hashes",
          "timestamps"
        ]
      }
    }
  ],
  "$defs": {
    "MutationRecord": {
      "type": "object",
      "required": ["path", "kind"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["file", "directory", "json", "yaml", "md", "txt", "other"] },
        "reason": { "type": "string" },
        "artifact_id": { "type": "string" }
      }
    },
    "MoveRecord": {
      "type": "object",
      "required": ["from_path", "to_path"],
      "additionalProperties": false,
      "properties": {
        "from_path": { "type": "string", "minLength": 1 },
        "to_path": { "type": "string", "minLength": 1 },
        "reason": { "type": "string" },
        "artifact_id": { "type": "string" }
      }
    }
  }
}
