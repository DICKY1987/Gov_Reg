{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newphaseplanprocess.schemas/01260207233100000672_coverage_v1.json",
  "title": "Coverage Data Schema v1",
  "description": "Schema for code coverage data including test coverage, gate coverage, and spine coverage. Used for validation and metrics reporting.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "schema_version",
    "coverage_metadata",
    "coverage_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this coverage schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "const": "1.0.0"
    },
    "coverage_metadata": {
      "type": "object",
      "description": "Metadata about coverage collection",
      "required": ["collected_at", "coverage_tool", "coverage_types"],
      "properties": {
        "collected_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of coverage collection"
        },
        "coverage_tool": {
          "type": "string",
          "description": "Tool used for coverage collection",
          "examples": ["pytest-cov", "coverage.py", "istanbul", "jacoco"]
        },
        "coverage_tool_version": {
          "type": "string",
          "description": "Version of coverage tool",
          "pattern": "^\\d+\\.\\d+\\.\\d+.*$"
        },
        "coverage_types": {
          "type": "array",
          "description": "Types of coverage collected",
          "items": {
            "type": "string",
            "enum": [
              "line",
              "branch",
              "function",
              "statement",
              "gate",
              "spine",
              "artifact",
              "automation"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "plan_id": {
          "type": "string",
          "description": "Plan ID this coverage is for",
          "pattern": "^PLAN-[A-Z0-9]{8,16}$"
        },
        "execution_environment": {
          "type": "string",
          "enum": ["local", "ci", "staging", "production"],
          "description": "Where coverage was collected"
        }
      }
    },
    "coverage_summary": {
      "type": "object",
      "description": "High-level coverage summary",
      "required": ["overall_coverage_percent"],
      "properties": {
        "overall_coverage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Overall coverage percentage"
        },
        "line_coverage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Line coverage percentage"
        },
        "branch_coverage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Branch coverage percentage"
        },
        "function_coverage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Function coverage percentage"
        },
        "total_lines": {
          "type": "integer",
          "minimum": 0,
          "description": "Total lines of code"
        },
        "covered_lines": {
          "type": "integer",
          "minimum": 0,
          "description": "Lines covered by tests"
        },
        "uncovered_lines": {
          "type": "integer",
          "minimum": 0,
          "description": "Lines not covered by tests"
        },
        "total_branches": {
          "type": "integer",
          "minimum": 0
        },
        "covered_branches": {
          "type": "integer",
          "minimum": 0
        },
        "total_functions": {
          "type": "integer",
          "minimum": 0
        },
        "covered_functions": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "file_coverage": {
      "type": "array",
      "description": "Per-file coverage details",
      "items": {
        "type": "object",
        "required": ["file_path", "coverage_percent"],
        "properties": {
          "file_path": {
            "type": "string",
            "description": "Relative path to file"
          },
          "file_type": {
            "type": "string",
            "enum": [
              "source",
              "test",
              "script",
              "config"
            ]
          },
          "coverage_percent": {
            "type": "number",
            "minimum": 0,
            "maximum": 100
          },
          "lines_total": {
            "type": "integer",
            "minimum": 0
          },
          "lines_covered": {
            "type": "integer",
            "minimum": 0
          },
          "lines_uncovered": {
            "type": "integer",
            "minimum": 0
          },
          "uncovered_line_numbers": {
            "type": "array",
            "description": "Line numbers not covered",
            "items": {
              "type": "integer",
              "minimum": 1
            }
          },
          "branches_total": {
            "type": "integer",
            "minimum": 0
          },
          "branches_covered": {
            "type": "integer",
            "minimum": 0
          },
          "functions_total": {
            "type": "integer",
            "minimum": 0
          },
          "functions_covered": {
            "type": "integer",
            "minimum": 0
          },
          "complexity": {
            "type": "integer",
            "minimum": 0,
            "description": "Cyclomatic complexity"
          }
        }
      }
    },
    "gate_coverage": {
      "type": "object",
      "description": "Validation gate coverage",
      "properties": {
        "total_gates": {
          "type": "integer",
          "minimum": 0,
          "description": "Total gates defined in plan"
        },
        "gates_with_validation": {
          "type": "integer",
          "minimum": 0,
          "description": "Gates with executable validation"
        },
        "gates_without_validation": {
          "type": "integer",
          "minimum": 0,
          "description": "Gates without validation"
        },
        "gate_coverage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of gates with validation"
        },
        "gate_details": {
          "type": "array",
          "description": "Per-gate coverage details",
          "items": {
            "type": "object",
            "required": ["gate_id", "has_validation"],
            "properties": {
              "gate_id": {
                "type": "string",
                "pattern": "^GATE-\\d{3}$"
              },
              "gate_name": {
                "type": "string"
              },
              "has_validation": {
                "type": "boolean",
                "description": "Whether gate has executable validation"
              },
              "validation_command": {
                "type": "string",
                "description": "Command used for validation"
              },
              "last_executed": {
                "type": "string",
                "format": "date-time",
                "description": "Last execution timestamp"
              },
              "execution_count": {
                "type": "integer",
                "minimum": 0,
                "description": "Number of times gate executed"
              },
              "last_result": {
                "type": "string",
                "enum": ["passed", "failed", "skipped", "not_executed"]
              }
            }
          }
        }
      }
    },
    "spine_coverage": {
      "type": "object",
      "description": "Phase spine coverage mapping",
      "properties": {
        "total_phases": {
          "type": "integer",
          "minimum": 0
        },
        "phases_with_validation": {
          "type": "integer",
          "minimum": 0
        },
        "spine_coverage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of phases with validation coverage"
        },
        "phase_details": {
          "type": "array",
          "description": "Per-phase coverage details",
          "items": {
            "type": "object",
            "required": ["phase_id", "coverage_status"],
            "properties": {
              "phase_id": {
                "type": "string",
                "pattern": "^PH-\\d{2,4}$"
              },
              "phase_name": {
                "type": "string"
              },
              "coverage_status": {
                "type": "string",
                "enum": ["full", "partial", "none"]
              },
              "gates_assigned": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^GATE-\\d{3}$"
                }
              },
              "gates_executed": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^GATE-\\d{3}$"
                }
              },
              "coverage_gaps": {
                "type": "array",
                "description": "Areas not covered by validation",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "artifact_coverage": {
      "type": "object",
      "description": "Artifact validation coverage",
      "properties": {
        "total_artifacts": {
          "type": "integer",
          "minimum": 0
        },
        "artifacts_validated": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_coverage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "artifact_details": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "artifact_id": {
                "type": "string"
              },
              "has_schema": {
                "type": "boolean"
              },
              "has_validation": {
                "type": "boolean"
              },
              "has_producer": {
                "type": "boolean"
              },
              "has_consumer": {
                "type": "boolean"
              },
              "validation_status": {
                "type": "string",
                "enum": ["validated", "not_validated", "validation_failed"]
              }
            }
          }
        }
      }
    },
    "automation_coverage": {
      "type": "object",
      "description": "Automation ratio and coverage",
      "properties": {
        "total_commands": {
          "type": "integer",
          "minimum": 0
        },
        "automated_commands": {
          "type": "integer",
          "minimum": 0
        },
        "manual_commands": {
          "type": "integer",
          "minimum": 0
        },
        "automation_ratio_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Percentage of automated commands"
        },
        "idempotent_commands": {
          "type": "integer",
          "minimum": 0,
          "description": "Commands verified as idempotent"
        },
        "non_idempotent_commands": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "threshold_compliance": {
      "type": "object",
      "description": "Compliance with coverage thresholds",
      "properties": {
        "thresholds": {
          "type": "object",
          "description": "Defined thresholds",
          "properties": {
            "minimum_line_coverage": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "minimum_branch_coverage": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "minimum_gate_coverage": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            },
            "minimum_automation_ratio": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        },
        "compliance_status": {
          "type": "string",
          "enum": ["compliant", "non_compliant", "partially_compliant"],
          "description": "Overall threshold compliance"
        },
        "violations": {
          "type": "array",
          "description": "Threshold violations",
          "items": {
            "type": "object",
            "properties": {
              "threshold_name": {
                "type": "string"
              },
              "threshold_value": {
                "type": "number"
              },
              "actual_value": {
                "type": "number"
              },
              "deficit": {
                "type": "number",
                "description": "How much below threshold"
              }
            }
          }
        }
      }
    },
    "trends": {
      "type": "object",
      "description": "Coverage trends over time",
      "properties": {
        "previous_coverage_percent": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        },
        "coverage_change_percent": {
          "type": "number",
          "description": "Change from previous measurement"
        },
        "trend_direction": {
          "type": "string",
          "enum": ["improving", "declining", "stable"]
        },
        "historical_data_points": {
          "type": "array",
          "description": "Historical coverage measurements",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": {
                "type": "string",
                "format": "date-time"
              },
              "coverage_percent": {
                "type": "number",
                "minimum": 0,
                "maximum": 100
              }
            }
          }
        }
      }
    }
  }
}
