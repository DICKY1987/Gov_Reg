{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonomy.dev/schemas/plan/v2.4.0",
  "title": "Autonomous Delivery Plan v2.4.0",
  "description": "Deterministic execution plan with structured commands, ID-keyed maps, and formula-validated outputs. Guarantees: same input → same plan hash → byte-identical output (except timestamps).",

  "type": "object",
  "required": ["meta", "plan", "navigation"],
  "additionalProperties": false,

  "properties": {
    "meta": {
      "type": "object",
      "required": ["template_version", "plan_id", "created_at"],
      "additionalProperties": false,
      "properties": {
        "template_version": {
          "type": "string",
          "const": "2.4.0",
          "description": "Template version - updated to 2.4.0 for TMP process improvements"
        },
        "plan_id": {
          "type": "string",
          "pattern": "^PLAN-[A-Z0-9]{8,16}$",
          "description": "Unique plan identifier"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of plan creation"
        },
        "project_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },

    "plan": {
      "type": "object",
      "required": [
        "classification",
        "phases_by_id",
        "gates_by_id",
        "commands",
        "metrics",
        "parallel_execution",
        "self_healing",
        "determinism"
      ],
      "additionalProperties": false,
      "description": "ONLY EXECUTABLE SURFACE - canonical data in ID-keyed maps",

      "properties": {
        "classification": {
          "$ref": "#/$defs/classification"
        },

        "phases_by_id": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/phase" },
          "description": "CANONICAL: phases keyed by phase_id (e.g., PH-00_BOOTSTRAP)"
        },

        "gates_by_id": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/gate" },
          "description": "CANONICAL: gates keyed by gate_id (e.g., G-001)"
        },

        "commands": {
          "$ref": "#/$defs/commands"
        },

        "metrics": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/metric" },
          "description": "Metrics keyed by metric name"
        },

        "parallel_execution": {
          "$ref": "#/$defs/parallel_execution"
        },

        "self_healing": {
          "$ref": "#/$defs/self_healing"
        },

        "worktree_isolation": {
          "$ref": "#/$defs/worktree_isolation"
        },

        "infrastructure": {
          "$ref": "#/$defs/infrastructure"
        },

        "determinism": {
          "$ref": "#/$defs/determinism_config"
        },

        "log_fields": {
          "type": "object",
          "description": "EXPLICITLY IGNORED BY EXECUTOR - prose/metadata only",
          "additionalProperties": true,
          "properties": {
            "original_request": { "type": "string" },
            "assumptions": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/assumption" }
            },
            "decision_ledger": {
              "type": "object",
              "additionalProperties": { "$ref": "#/$defs/decision_entry" }
            },
            "scope": {
              "$ref": "#/$defs/scope_definition"
            }
          }
        }
      }
    },

    "navigation": {
      "type": "object",
      "required": ["generated_from", "algorithm_version"],
      "additionalProperties": false,
      "description": "DERIVED SECTION - regenerated by compiler, never executed",

      "properties": {
        "generated_from": {
          "const": "plan",
          "description": "ENFORCED: navigation is always derived from /plan"
        },
        "algorithm_version": {
          "type": "string",
          "pattern": "^nav-v[0-9]+\\.[0-9]+$",
          "description": "Navigation generation algorithm version"
        },
        "generated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when navigation was last regenerated"
        },
        "toc": {
          "type": "array",
          "items": { "$ref": "#/$defs/nav_item" },
          "description": "Table of contents with JSON Pointers into /plan"
        },
        "hierarchy": {
          "type": "array",
          "items": { "$ref": "#/$defs/nav_node" },
          "description": "Hierarchical navigation tree"
        },
        "index": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "pattern": "^/plan/(phases|gates|metrics)_by_id/[A-Z0-9_-]+$"
          },
          "description": "ID → JSON Pointer mapping (always references _by_id maps)"
        }
      }
    },

    "logs": {
      "type": "object",
      "description": "APPEND-ONLY execution logs - not read by executor",
      "additionalProperties": true
    }
  },

  "$defs": {
    "command_invocation": {
      "type": "object",
      "required": ["command_ref", "args"],
      "additionalProperties": false,
      "description": "Structured command reference - no shell parsing needed",
      "properties": {
        "command_ref": {
          "type": "string",
          "pattern": "^(STD|CMD)-[A-Z0-9_]+$",
          "description": "Must reference commands.standard_by_id[id] or commands.custom_by_id[id]"
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Command arguments (no quoting/escaping needed)"
        },
        "cwd": {
          "type": "string",
          "description": "Working directory (optional, defaults to phase file_scope root)"
        },
        "env": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Environment variables to set"
        },
        "stdin": {
          "type": "string",
          "description": "Optional stdin data"
        }
      }
    },

    "pattern_reference": {
      "type": "object",
      "required": ["library_ref"],
      "additionalProperties": false,
      "description": "Reference to regex pattern in determinism.regex_pattern_library",
      "properties": {
        "library_ref": {
          "type": "string",
          "enum": [
            "coverage_percentage",
            "test_pass_fail_counts",
            "build_success",
            "lint_clean",
            "no_errors",
            "exit_zero"
          ],
          "description": "Pattern name from library"
        },
        "substitutions": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "string" },
              { "type": "number" },
              { "type": "integer" }
            ]
          },
          "description": "Variable substitutions (e.g., {target_min: 95})"
        }
      }
    },

    "classification": {
      "type": "object",
      "required": ["complexity", "domain", "quality", "file_count_est", "loc_est"],
      "additionalProperties": false,
      "properties": {
        "complexity": {
          "enum": ["simple", "moderate", "complex", "enterprise"],
          "description": "Drives phase selection, coverage targets, verification level"
        },
        "domain": {
          "enum": ["technical", "analytical", "creative", "general"]
        },
        "quality": {
          "enum": ["standard", "high", "critical", "production"]
        },
        "file_count_est": {
          "type": "integer",
          "minimum": 1
        },
        "loc_est": {
          "type": "integer",
          "minimum": 1
        },
        "verification_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3,
          "description": "Auto-determined from complexity"
        },
        "test_coverage_min": {
          "type": "integer",
          "minimum": 70,
          "maximum": 100,
          "description": "MUST match determinism.metrics_target_formulas.test_coverage_min"
        }
      }
    },

    "phase": {
      "type": "object",
      "required": [
        "phase_id",
        "canonical_name",
        "goals",
        "dependencies",
        "estimated_time_min",
        "file_scope",
        "ground_truth_level"
      ],
      "additionalProperties": false,
      "properties": {
        "phase_id": {
          "type": "string",
          "pattern": "^PH-[0-9]{2}_[A-Z_]+$",
          "description": "Must match determinism.phase_naming_rules.canonical_names"
        },
        "canonical_name": {
          "enum": [
            "BOOTSTRAP",
            "ARCHITECTURE",
            "CONTRACTS",
            "CORE_IMPLEMENTATION",
            "FEATURE_IMPLEMENTATION",
            "INTEGRATION",
            "HARDENING",
            "PACKAGING",
            "RELEASE",
            "OPERATIONS"
          ]
        },
        "goals": {
          "type": "array",
          "items": { "type": "string", "minLength": 10 },
          "minItems": 1
        },
        "deliverables": {
          "type": "array",
          "items": { "type": "string" }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^PH-[0-9]{2}_[A-Z_]+$"
          },
          "description": "Phase IDs this depends on (must exist and be acyclic)"
        },
        "estimated_time_min": {
          "type": "integer",
          "minimum": 1,
          "description": "MUST match determinism.time_estimation_formulas computation"
        },
        "file_scope": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Glob patterns (sorted lexicographically, no overlaps)"
        },
        "ground_truth_level": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "contracts": {
          "$ref": "#/$defs/phase_contract"
        }
      }
    },

    "phase_contract": {
      "type": "object",
      "required": ["inputs", "outputs", "preconditions", "postconditions"],
      "additionalProperties": false,
      "properties": {
        "inputs": {
          "type": "object",
          "properties": {
            "required_files": { "type": "array", "items": { "type": "string" } },
            "required_state": { "type": "array", "items": { "type": "string" } }
          }
        },
        "outputs": {
          "type": "object",
          "properties": {
            "created_files": { "type": "array", "items": { "type": "string" } },
            "modified_files": { "type": "array", "items": { "type": "string" } },
            "evidence_artifacts": {
              "type": "array",
              "items": { "type": "string", "pattern": "^\\.state/evidence/" }
            }
          }
        },
        "preconditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition", "validation"],
            "properties": {
              "condition": { "type": "string" },
              "validation": { "$ref": "#/$defs/command_invocation" }
            }
          }
        },
        "postconditions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["condition", "validation"],
            "properties": {
              "condition": { "type": "string" },
              "validation": { "$ref": "#/$defs/command_invocation" }
            }
          }
        },
        "invariants": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failure_modes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["failure_type", "detection", "remediation"],
            "properties": {
              "failure_type": { "type": "string" },
              "detection": { "type": "string" },
              "remediation": { "type": "string" }
            }
          }
        }
      }
    },

    "gate": {
      "type": "object",
      "required": [
        "gate_id",
        "phase_id",
        "purpose",
        "command",
        "expect_exit_code",
        "evidence"
      ],
      "additionalProperties": false,
      "properties": {
        "gate_id": {
          "type": "string",
          "pattern": "^G-[0-9]{3}$"
        },
        "phase_id": {
          "type": "string",
          "pattern": "^PH-[0-9]{2}_[A-Z_]+$",
          "description": "Must exist in phases_by_id"
        },
        "purpose": {
          "type": "string",
          "minLength": 10,
          "maxLength": 200
        },
        "command": {
          "$ref": "#/$defs/command_invocation"
        },
        "timeout_sec": {
          "type": "integer",
          "minimum": 1,
          "maximum": 3600
        },
        "retries": {
          "type": "integer",
          "minimum": 0,
          "maximum": 2
        },
        "expect_exit_code": {
          "type": "integer"
        },
        "expect_stdout_patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/pattern_reference" },
          "description": "Patterns that MUST appear in stdout"
        },
        "forbid_stdout_patterns": {
          "type": "array",
          "items": { "$ref": "#/$defs/pattern_reference" },
          "description": "Patterns that MUST NOT appear in stdout"
        },
        "expect_files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "content_patterns": {
                "type": "array",
                "items": { "$ref": "#/$defs/pattern_reference" }
              },
              "min_size_bytes": { "type": "integer", "minimum": 0 },
              "max_size_bytes": { "type": "integer", "minimum": 0 }
            }
          }
        },
        "evidence": {
          "type": "string",
          "pattern": "^\\.state/evidence/",
          "description": "Evidence artifact path"
        }
      }
    },

    "commands": {
      "type": "object",
      "required": ["standard_by_id", "custom_by_id"],
      "additionalProperties": false,
      "properties": {
        "standard_by_id": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/standard_command" },
          "description": "Standard commands keyed by ID (e.g., STD-PYTHON)"
        },
        "custom_by_id": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/custom_command" },
          "description": "Custom commands keyed by ID (e.g., CMD-VALIDATE_PLAN)"
        }
      }
    },

    "standard_command": {
      "type": "object",
      "required": ["id", "entrypoint"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^STD-[A-Z0-9_]+$",
          "description": "e.g., STD-PYTHON, STD-GIT, STD-PYTEST"
        },
        "entrypoint": {
          "type": "string",
          "description": "Exact command to invoke (no arguments)"
        },
        "version_check": {
          "type": "object",
          "required": ["args"],
          "properties": {
            "args": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Arguments for version check (e.g., ['--version'])"
            },
            "expect_stdout_pattern": {
              "$ref": "#/$defs/pattern_reference"
            }
          }
        },
        "version_spec": {
          "type": "string",
          "description": "Version constraint (e.g., '>=3.9', '~=1.2.3')"
        }
      }
    },

    "custom_command": {
      "type": "object",
      "required": [
        "id",
        "purpose",
        "implementation_path",
        "build_phase",
        "entrypoint",
        "verification"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^CMD-[A-Z0-9_]+$"
        },
        "purpose": {
          "type": "string",
          "minLength": 10,
          "maxLength": 200
        },
        "implementation_path": {
          "type": "string"
        },
        "build_phase": {
          "type": "string",
          "pattern": "^PH-[0-9]{2}_[A-Z_]+$",
          "description": "Must be earlier than phases that use this command"
        },
        "entrypoint": {
          "type": "string"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "verification": {
          "type": "object",
          "required": ["command", "expect_exit_code", "evidence"],
          "additionalProperties": false,
          "properties": {
            "command": { "$ref": "#/$defs/command_invocation" },
            "expect_exit_code": { "type": "integer" },
            "expect_stdout_patterns": {
              "type": "array",
              "items": { "$ref": "#/$defs/pattern_reference" }
            },
            "evidence": {
              "type": "string",
              "pattern": "^\\.state/evidence/"
            }
          }
        },
        "outputs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "metric": {
      "type": "object",
      "required": ["name", "type", "unit", "target"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z_][a-z0-9_]*$"
        },
        "type": {
          "enum": ["timer", "counter", "gauge", "ratio"]
        },
        "unit": {
          "enum": ["sec", "min", "count", "percent", "ms", "bytes", "ratio"]
        },
        "target": {
          "type": "string",
          "pattern": "^(<|<=|>|>=|==)\\s*[0-9]+(\\.[0-9]+)?(%)?$"
        },
        "formula": {
          "type": "string"
        },
        "validation": {
          "type": "object",
          "required": ["command"],
          "properties": {
            "command": { "$ref": "#/$defs/command_invocation" },
            "evidence": { "type": "string", "pattern": "^\\.state/" }
          }
        },
        "threshold_enforced_in_command": {
          "type": "boolean",
          "description": "TMP-04: Whether the validation command enforces the metric threshold (e.g., assert coverage >= target)"
        }
      }
    },

    "parallel_execution": {
      "type": "object",
      "required": ["enabled", "groups"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "max_concurrent": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "scheduling_policy": {
          "enum": ["priority_queue", "fifo", "lifo"]
        },
        "groups": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["group_id", "phases", "parallelism", "estimated_time_min"],
            "additionalProperties": false,
            "properties": {
              "group_id": {
                "type": "integer",
                "minimum": 0,
                "description": "Topological level (0-based)"
              },
              "phases": {
                "type": "array",
                "items": { "type": "string", "pattern": "^PH-[0-9]{2}_[A-Z_]+$" },
                "minItems": 1,
                "description": "Phase IDs (must be sorted lexicographically)"
              },
              "parallelism": {
                "type": "integer",
                "minimum": 1
              },
              "estimated_time_min": {
                "type": "integer",
                "minimum": 1,
                "description": "MAX(phase times) in this group"
              },
              "rationale": { "type": "string" }
            }
          },
          "description": "Groups sorted by group_id ASC"
        },
        "time_estimate": {
          "type": "object",
          "required": ["sequential_total_min", "parallel_total_min", "speedup_percent"],
          "properties": {
            "sequential_total_min": { "type": "integer", "minimum": 1 },
            "parallel_total_min": { "type": "integer", "minimum": 1 },
            "speedup_percent": {
              "type": "number",
              "minimum": 0,
              "maximum": 100
            }
          }
        }
      }
    },

    "self_healing": {
      "type": "object",
      "required": ["enabled", "budgets", "failure_types"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "budgets": {
          "type": "object",
          "required": ["per_phase_max_attempts", "per_gate_max_attempts", "global_max_attempts"],
          "additionalProperties": false,
          "properties": {
            "per_phase_max_attempts": { "type": "integer", "minimum": 1, "maximum": 3 },
            "per_gate_max_attempts": { "type": "integer", "minimum": 0, "maximum": 2 },
            "global_max_attempts": { "type": "integer", "minimum": 1 }
          }
        },
        "failure_types": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": ["id", "allowed_actions", "max_attempts", "commands"],
            "additionalProperties": false,
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^FAIL-[A-Z_]+$"
              },
              "allowed_actions": {
                "type": "array",
                "items": { "type": "string" },
                "minItems": 3,
                "maxItems": 3,
                "description": "EXACTLY 3 actions per determinism rules"
              },
              "max_attempts": {
                "type": "integer",
                "minimum": 1,
                "maximum": 3
              },
              "abort_if": {
                "type": "array",
                "items": { "type": "string" }
              },
              "commands": {
                "type": "object",
                "additionalProperties": { "$ref": "#/$defs/command_invocation" },
                "description": "Map of action → command_invocation"
              }
            }
          },
          "description": "Failure types keyed by ID"
        },
        "convergence_detection": {
          "type": "object",
          "required": ["metric", "threshold", "window", "action_if_not_converging"],
          "properties": {
            "metric": { "type": "string" },
            "threshold": { "type": "string" },
            "window": { "type": "integer", "minimum": 2 },
            "action_if_not_converging": {
              "enum": ["abort_and_escalate", "continue", "manual_intervention"]
            }
          }
        }
      }
    },

    "worktree_isolation": {
      "type": "object",
      "required": ["enabled", "base_ref", "max_parallel"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "base_ref": {
          "type": "string",
          "pattern": "^[a-zA-Z0-9/_-]+$"
        },
        "max_parallel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 32
        },
        "naming": {
          "type": "object",
          "required": ["pattern", "branch_pattern"],
          "properties": {
            "pattern": { "type": "string" },
            "branch_pattern": { "type": "string" }
          }
        },
        "merge_strategy": {
          "enum": ["squash", "rebase", "merge"]
        },
        "conflict_policy": {
          "enum": ["abort_and_escalate", "keep_ours", "keep_theirs", "manual"]
        }
      }
    },

    "infrastructure": {
      "type": "object",
      "required": ["required", "resources_min"],
      "additionalProperties": false,
      "properties": {
        "required": {
          "type": "object",
          "properties": {
            "os": {
              "type": "array",
              "items": {
                "enum": ["linux", "macos", "windows", "ubuntu", "debian", "centos", "alpine"]
              },
              "minItems": 1
            }
          },
          "additionalProperties": {
            "type": "object",
            "required": ["version", "validation"],
            "properties": {
              "version": { "type": "string" },
              "validation": { "$ref": "#/$defs/command_invocation" }
            }
          }
        },
        "optional": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "version": { "type": "string" },
              "validation": { "$ref": "#/$defs/command_invocation" },
              "required_for": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "resources_min": {
          "type": "object",
          "required": ["ram_gb", "disk_free_gb"],
          "properties": {
            "ram_gb": { "type": "number", "minimum": 0.5 },
            "disk_free_gb": { "type": "number", "minimum": 1 },
            "cpu_cores": { "type": "integer", "minimum": 1 },
            "validation": { "$ref": "#/$defs/command_invocation" }
          }
        },
        "permissions": {
          "type": "object",
          "properties": {
            "filesystem_write": { "type": "boolean" },
            "network_access": { "enum": ["none", "conditional", "full"] },
            "network_allowlist": {
              "type": "array",
              "items": { "type": "string", "format": "hostname" }
            }
          }
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["name", "version", "purpose"],
              "properties": {
                "name": { "type": "string" },
                "version": { "type": "string" },
                "purpose": { "type": "string" },
                "dev_only": { "type": "boolean" }
              }
            }
          }
        },
        "command_platform_audit": {
          "type": "object",
          "description": "TMP-06: OS-incompatible command detection for multi-platform plans",
          "properties": {
            "description": { "type": "string" },
            "enabled_when": { "type": "string" },
            "forbidden_patterns": {
              "type": "object",
              "additionalProperties": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["pattern", "alternative"],
                  "properties": {
                    "pattern": { "type": "string" },
                    "alternative": { "type": "string" }
                  }
                }
              }
            },
            "enforcement": { "type": "string" },
            "remediation": { "type": "string" }
          }
        }
      }
    },

    "determinism_config": {
      "type": "object",
      "required": [
        "quantification_rules",
        "phase_naming_rules",
        "parallelization_rules",
        "regex_pattern_library",
        "time_estimation_formulas",
        "metrics_target_formulas",
        "impact_scoring_rubric"
      ],
      "additionalProperties": false,
      "description": "FROZEN RULES - not modified during execution",

      "properties": {
        "quantification_rules": {
          "type": "object",
          "required": [
            "targets_count",
            "assumptions_count",
            "gates_count",
            "limitations_count",
            "actions_per_failure_type"
          ],
          "additionalProperties": false,
          "properties": {
            "targets_count": {
              "type": "object",
              "required": ["formula"],
              "properties": {
                "formula": { "type": "string" },
                "rationale_required": { "type": "boolean" }
              }
            },
            "assumptions_count": {
              "type": "object",
              "required": ["formula"],
              "properties": {
                "formula": { "type": "string" },
                "rationale_required": { "type": "boolean" }
              }
            },
            "gates_count": {
              "type": "object",
              "required": ["by_complexity", "phase_adjustment", "final_formula"],
              "properties": {
                "by_complexity": {
                  "type": "object",
                  "required": ["simple", "moderate", "complex", "enterprise"],
                  "properties": {
                    "simple": { "type": "integer", "const": 8 },
                    "moderate": { "type": "integer", "const": 12 },
                    "complex": { "type": "integer", "const": 16 },
                    "enterprise": { "type": "integer", "const": 20 }
                  }
                },
                "phase_adjustment": {
                  "type": "object",
                  "required": ["formula"],
                  "properties": {
                    "formula": { "type": "string" }
                  }
                },
                "final_formula": { "type": "string" }
              }
            },
            "limitations_count": {
              "type": "object",
              "required": ["by_complexity", "formula"],
              "properties": {
                "by_complexity": {
                  "type": "object",
                  "required": ["simple", "moderate", "complex", "enterprise"],
                  "properties": {
                    "simple": { "type": "integer", "const": 3 },
                    "moderate": { "type": "integer", "const": 4 },
                    "complex": { "type": "integer", "const": 5 },
                    "enterprise": { "type": "integer", "const": 5 }
                  }
                },
                "formula": { "type": "string" }
              }
            },
            "actions_per_failure_type": {
              "type": "object",
              "required": ["formula"],
              "properties": {
                "formula": { "type": "string", "const": "3" },
                "rationale_required": { "type": "boolean" }
              }
            }
          }
        },

        "phase_naming_rules": {
          "type": "object",
          "required": ["format", "canonical_names", "phase_selection_rules"],
          "additionalProperties": false,
          "properties": {
            "format": { "type": "string" },
            "canonical_names": {
              "type": "array",
              "items": { "type": "string", "pattern": "^PH-[0-9]{2}_[A-Z_]+$" },
              "minItems": 10,
              "uniqueItems": true
            },
            "phase_selection_rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["if", "phases"],
                "properties": {
                  "if": { "type": "string" },
                  "phases": { "type": "array", "items": { "type": "string" } }
                }
              },
              "minItems": 4
            }
          }
        },

        "parallelization_rules": {
          "type": "object",
          "required": [
            "required",
            "dependency_matrix_required",
            "grouping_algorithm",
            "grouping_steps",
            "deterministic_ordering"
          ],
          "additionalProperties": false,
          "properties": {
            "required": { "type": "boolean" },
            "dependency_matrix_required": { "type": "boolean" },
            "grouping_algorithm": {
              "enum": ["topological_levels", "maximum_independent_set"]
            },
            "grouping_steps": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 3
            },
            "deterministic_ordering": {
              "type": "object",
              "required": ["within_group", "group_order"],
              "properties": {
                "within_group": { "type": "string" },
                "group_order": { "type": "string" }
              }
            }
          }
        },

        "regex_pattern_library": {
          "type": "object",
          "required": [
            "coverage_percentage",
            "test_pass_fail_counts",
            "build_success",
            "lint_clean"
          ],
          "additionalProperties": {
            "type": "object",
            "required": ["pattern"],
            "properties": {
              "pattern": { "type": "string" },
              "capture_group": { "type": "string" },
              "capture_groups": { "type": "array", "items": { "type": "string" } },
              "validate": { "type": "string" }
            }
          }
        },

        "time_estimation_formulas": {
          "type": "object",
          "required": ["per_phase_base_min", "complexity_multiplier", "final_formula"],
          "additionalProperties": false,
          "properties": {
            "per_phase_base_min": {
              "type": "object",
              "additionalProperties": {
                "anyOf": [
                  { "type": "integer" },
                  { "type": "string" }
                ]
              }
            },
            "complexity_multiplier": {
              "type": "object",
              "required": ["simple", "moderate", "complex", "enterprise"],
              "properties": {
                "simple": { "type": "number", "const": 1.0 },
                "moderate": { "type": "number", "const": 1.2 },
                "complex": { "type": "number", "const": 1.5 },
                "enterprise": { "type": "number", "const": 2.0 }
              }
            },
            "final_formula": { "type": "string" }
          }
        },

        "metrics_target_formulas": {
          "type": "object",
          "required": ["test_coverage_min", "gate_pass_rate"],
          "additionalProperties": false,
          "properties": {
            "test_coverage_min": {
              "type": "object",
              "required": ["by_complexity", "by_quality", "formula"],
              "properties": {
                "by_complexity": {
                  "type": "object",
                  "required": ["simple", "moderate", "complex", "enterprise"],
                  "properties": {
                    "simple": { "type": "integer", "const": 70 },
                    "moderate": { "type": "integer", "const": 80 },
                    "complex": { "type": "integer", "const": 90 },
                    "enterprise": { "type": "integer", "const": 95 }
                  }
                },
                "by_quality": {
                  "type": "object",
                  "required": ["standard", "high", "critical", "production"],
                  "properties": {
                    "standard": { "type": "integer", "const": 0 },
                    "high": { "type": "integer", "const": 5 },
                    "critical": { "type": "integer", "const": 10 },
                    "production": { "type": "integer", "const": 10 }
                  }
                },
                "formula": { "type": "string" }
              }
            },
            "gate_pass_rate": {
              "type": "object",
              "required": ["always"],
              "properties": {
                "always": { "type": "integer", "const": 100 }
              }
            }
          }
        },

        "impact_scoring_rubric": {
          "type": "object",
          "required": ["blocking_scope", "failure_cost", "validation_difficulty", "class_thresholds"],
          "additionalProperties": false,
          "properties": {
            "blocking_scope": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "failure_cost": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "validation_difficulty": {
              "type": "object",
              "additionalProperties": { "type": "string" }
            },
            "class_thresholds": {
              "type": "object",
              "required": ["LOW", "MEDIUM", "HIGH"],
              "properties": {
                "LOW": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "MEDIUM": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "minItems": 2,
                  "maxItems": 2
                },
                "HIGH": {
                  "type": "array",
                  "items": { "type": "integer" },
                  "minItems": 2,
                  "maxItems": 2
                }
              }
            }
          }
        },

        "file_scope_specification_rules": {
          "type": "object",
          "properties": {
            "format": { "type": "string" },
            "granularity": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["if", "specify"],
                "properties": {
                  "if": { "type": "string" },
                  "specify": { "type": "string" }
                }
              }
            }
          }
        },

        "custom_command_scheduling_rules": {
          "type": "object",
          "properties": {
            "assignment_algorithm": { "type": "string" },
            "constraints": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        },

        "plan_hash": {
          "type": "object",
          "properties": {
            "algorithm": {
              "enum": ["SHA256", "SHA512", "BLAKE2b"]
            },
            "inputs_normalization": {
              "type": "array",
              "items": { "type": "string" }
            },
            "hash_inputs": {
              "type": "array",
              "items": { "type": "string" }
            }
          }
        }
      }
    },

    "assumption": {
      "type": "object",
      "required": ["id", "category", "assumption", "impact_score"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^ASM-[A-Z0-9]+-[0-9]{3}$"
        },
        "category": {
          "enum": ["technical", "scope", "constraint", "input"]
        },
        "assumption": { "type": "string", "minLength": 10 },
        "impact_score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "validation_status": {
          "enum": ["unvalidated", "confirmed", "invalidated"]
        },
        "validation_method": { "type": "string" },
        "validation": {
          "type": "object",
          "properties": {
            "command": { "$ref": "#/$defs/command_invocation" },
            "expect_exit_code": { "type": "integer" },
            "expect_stdout_regex": {
              "type": "string",
              "description": "TMP-05: Regex that validation command stdout must match to confirm the assumption"
            }
          }
        },
        "logged_at": { "type": "string", "format": "date-time" }
      }
    },

    "decision_entry": {
      "type": "object",
      "required": [
        "decision_id",
        "category",
        "context",
        "options",
        "selected_option",
        "rationale",
        "timestamp"
      ],
      "additionalProperties": false,
      "properties": {
        "decision_id": {
          "type": "string",
          "pattern": "^DEC-[A-Z0-9]+-[0-9]{3}$"
        },
        "category": {
          "enum": [
            "classification",
            "phase_selection",
            "parallelization_strategy",
            "ground_truth_level",
            "tooling_choice",
            "architecture",
            "technology"
          ]
        },
        "context": { "type": "object" },
        "options": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "selected_option": { "type": "string" },
        "rationale": {
          "type": "string",
          "minLength": 20,
          "maxLength": 500
        },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },

    "scope_definition": {
      "type": "object",
      "required": ["in_scope", "out_of_scope", "definition_of_done"],
      "additionalProperties": false,
      "properties": {
        "in_scope": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "definition_of_done": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gate_id", "command", "expect"],
            "properties": {
              "gate_id": { "type": "string" },
              "command": { "$ref": "#/$defs/command_invocation" },
              "expect": { "type": "string" },
              "evidence": { "type": "string" }
            }
          }
        }
      }
    },

    "nav_item": {
      "type": "object",
      "required": ["title", "ptr"],
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "ptr": {
          "type": "string",
          "pattern": "^/plan/(phases|gates|metrics|commands)(_by_id)?(/[A-Z0-9_-]+)?$",
          "description": "ENFORCED: Must reference ID-keyed maps or top-level arrays"
        }
      }
    },

    "nav_node": {
      "type": "object",
      "required": ["id", "ptr"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "ptr": {
          "type": "string",
          "pattern": "^/plan/(phases|gates|metrics)_by_id/[A-Z0-9_-]+$",
          "description": "ENFORCED: Must reference _by_id maps"
        },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/nav_node" }
        }
      }
    }
  }
}
