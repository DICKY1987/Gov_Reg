{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://newphaseplanprocess.schemas/etl/01260207233100000733_raw_data.json",
  "title": "ETL Raw Data Schema",
  "description": "Schema for raw data extracted in ETL pipeline before transformation. Defines structure of unprocessed input data from phase plans including phases, artifacts, commands, and gates.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "schema_version",
    "extraction_metadata",
    "raw_phases",
    "raw_artifacts",
    "raw_commands",
    "raw_gates"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Version of this raw data schema",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "examples": ["1.0.0"]
    },
    "extraction_metadata": {
      "type": "object",
      "description": "Metadata about the extraction process",
      "required": ["extracted_at", "source_plan_id", "extractor_version"],
      "properties": {
        "extracted_at": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp of extraction"
        },
        "source_plan_id": {
          "type": "string",
          "description": "Plan ID that was extracted",
          "pattern": "^PLAN-[A-Z0-9]{8,16}$"
        },
        "source_plan_path": {
          "type": "string",
          "description": "File path to source plan"
        },
        "extractor_version": {
          "type": "string",
          "description": "Version of extraction tool",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "extraction_mode": {
          "type": "string",
          "enum": ["full", "incremental", "selective"],
          "description": "Type of extraction performed"
        }
      }
    },
    "raw_phases": {
      "type": "array",
      "description": "Raw phase data extracted from plan",
      "items": {
        "type": "object",
        "required": ["phase_id", "phase_name"],
        "properties": {
          "phase_id": {
            "type": "string",
            "description": "Unique phase identifier",
            "pattern": "^PH-\\d{2,4}$"
          },
          "phase_name": {
            "type": "string",
            "description": "Human-readable phase name"
          },
          "description": {
            "type": "string",
            "description": "Phase description"
          },
          "depends_on": {
            "type": "array",
            "description": "Phase IDs this phase depends on",
            "items": {
              "type": "string",
              "pattern": "^PH-\\d{2,4}$"
            }
          },
          "gates": {
            "type": "array",
            "description": "Gate IDs for this phase",
            "items": {
              "type": "string",
              "pattern": "^GATE-\\d{3}$"
            }
          },
          "complexity": {
            "type": "string",
            "enum": ["trivial", "simple", "moderate", "complex", "critical"],
            "description": "Phase complexity level"
          },
          "estimated_duration_hours": {
            "type": "number",
            "minimum": 0,
            "description": "Estimated phase duration in hours"
          },
          "raw_metadata": {
            "type": "object",
            "description": "Additional unstructured phase metadata"
          }
        }
      }
    },
    "raw_artifacts": {
      "type": "array",
      "description": "Raw artifact data extracted from plan",
      "items": {
        "type": "object",
        "required": ["artifact_id", "artifact_type"],
        "properties": {
          "artifact_id": {
            "type": "string",
            "description": "Unique artifact identifier"
          },
          "artifact_type": {
            "type": "string",
            "enum": [
              "source_file",
              "test_file",
              "config_file",
              "documentation",
              "schema",
              "script",
              "evidence",
              "report",
              "data_file"
            ],
            "description": "Type of artifact"
          },
          "artifact_path": {
            "type": "string",
            "description": "File path or location of artifact"
          },
          "producer_phase": {
            "type": "string",
            "description": "Phase ID that produces this artifact",
            "pattern": "^PH-\\d{2,4}$"
          },
          "consumer_phases": {
            "type": "array",
            "description": "Phase IDs that consume this artifact",
            "items": {
              "type": "string",
              "pattern": "^PH-\\d{2,4}$"
            }
          },
          "write_method": {
            "type": "string",
            "enum": ["create", "update", "append", "delete"],
            "description": "How artifact is written"
          },
          "schema_ref": {
            "type": "string",
            "description": "Reference to schema defining artifact structure"
          },
          "raw_metadata": {
            "type": "object",
            "description": "Additional unstructured artifact metadata"
          }
        }
      }
    },
    "raw_commands": {
      "type": "array",
      "description": "Raw command data extracted from plan",
      "items": {
        "type": "object",
        "required": ["command_id", "command"],
        "properties": {
          "command_id": {
            "type": "string",
            "description": "Unique command identifier",
            "pattern": "^CMD-\\d{3,6}$"
          },
          "command": {
            "type": "string",
            "description": "Executable command string"
          },
          "description": {
            "type": "string",
            "description": "Human-readable command description"
          },
          "phase_id": {
            "type": "string",
            "description": "Phase this command belongs to",
            "pattern": "^PH-\\d{2,4}$"
          },
          "execution_order": {
            "type": "integer",
            "minimum": 0,
            "description": "Order of execution within phase"
          },
          "timeout_seconds": {
            "type": "integer",
            "minimum": 1,
            "description": "Command timeout in seconds"
          },
          "retry_policy": {
            "type": "object",
            "description": "Retry configuration",
            "properties": {
              "max_retries": {
                "type": "integer",
                "minimum": 0
              },
              "retry_delay_seconds": {
                "type": "integer",
                "minimum": 0
              }
            }
          },
          "raw_metadata": {
            "type": "object",
            "description": "Additional unstructured command metadata"
          }
        }
      }
    },
    "raw_gates": {
      "type": "array",
      "description": "Raw gate data extracted from plan",
      "items": {
        "type": "object",
        "required": ["gate_id", "gate_type"],
        "properties": {
          "gate_id": {
            "type": "string",
            "description": "Unique gate identifier",
            "pattern": "^GATE-\\d{3}$"
          },
          "gate_type": {
            "type": "string",
            "enum": [
              "validation",
              "test",
              "compliance",
              "security",
              "performance",
              "integration"
            ],
            "description": "Type of validation gate"
          },
          "gate_name": {
            "type": "string",
            "description": "Human-readable gate name"
          },
          "validation_command": {
            "type": "string",
            "description": "Command to execute gate validation"
          },
          "success_pattern": {
            "type": "string",
            "description": "Regex pattern for success detection"
          },
          "phase_id": {
            "type": "string",
            "description": "Phase this gate validates",
            "pattern": "^PH-\\d{2,4}$"
          },
          "depends_on_gates": {
            "type": "array",
            "description": "Gate IDs this gate depends on",
            "items": {
              "type": "string",
              "pattern": "^GATE-\\d{3}$"
            }
          },
          "evidence_output_path": {
            "type": "string",
            "description": "Path where gate evidence is stored"
          },
          "raw_metadata": {
            "type": "object",
            "description": "Additional unstructured gate metadata"
          }
        }
      }
    },
    "extraction_errors": {
      "type": "array",
      "description": "Errors encountered during extraction",
      "items": {
        "type": "object",
        "required": ["error_code", "error_message"],
        "properties": {
          "error_code": {
            "type": "string",
            "description": "Error classification code"
          },
          "error_message": {
            "type": "string",
            "description": "Detailed error description"
          },
          "error_location": {
            "type": "string",
            "description": "Location in source where error occurred"
          },
          "severity": {
            "type": "string",
            "enum": ["warning", "error", "critical"],
            "description": "Error severity level"
          }
        }
      }
    },
    "extraction_statistics": {
      "type": "object",
      "description": "Statistics about extracted data",
      "properties": {
        "total_phases": {
          "type": "integer",
          "minimum": 0
        },
        "total_artifacts": {
          "type": "integer",
          "minimum": 0
        },
        "total_commands": {
          "type": "integer",
          "minimum": 0
        },
        "total_gates": {
          "type": "integer",
          "minimum": 0
        },
        "extraction_duration_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "Time taken for extraction in milliseconds"
        }
      }
    }
  }
}
