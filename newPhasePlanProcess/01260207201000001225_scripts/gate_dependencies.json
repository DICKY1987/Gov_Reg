      "required": false,
      "timeout_sec": 180
    },
    {
      "id": "GATE-014",
      "name": "Artifact Closure",
      "script": "validate_artifact_closure.py",
      "phase": "validation",
      "depends_on": ["GATE-003"],
      "required": false,
      "timeout_sec": 180
