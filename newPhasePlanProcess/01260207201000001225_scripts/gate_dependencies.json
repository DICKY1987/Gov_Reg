{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "document_id": "GATE-DEPENDENCY-GRAPH-001",
  "version": "1.0.0",
  "created_at": "2026-03-05T10:54:00Z",
  "purpose": "Define validation gate execution order and dependencies for newPhasePlanProcess v3.0.0",
  "execution_model": "topologically_sorted_dag",
  "gates": [
    {
      "id": "GATE-000",
      "name": "No Obfuscation Check",
      "script": "validate_plan_structure.py",
      "phase": "pre-validation",
      "depends_on": [],
      "required": true,
      "timeout_sec": 60
    },
    {
      "id": "GATE-001",
      "name": "Schema Validation",
      "script": "P_01260207233100000263_validate_structure.py",
      "phase": "core-validation",
      "depends_on": ["GATE-000"],
      "required": true,
      "timeout_sec": 60
    },
    {
      "id": "GATE-002",
      "name": "Gate Definitions Valid",
      "script": "P_01260207233100000253_validate_gates.py",
      "phase": "core-validation",
      "depends_on": ["GATE-001"],
      "required": true,
      "timeout_sec": 60
    },
    {
      "id": "GATE-003",
      "name": "Step Contracts Complete",
      "script": "P_01260207233100000262_validate_step_contracts.py",
      "phase": "core-validation",
      "depends_on": ["GATE-001", "GATE-002"],
      "required": true,
      "timeout_sec": 300,
      "critical_rule": "All 13 contract fields mandatory for every step",
      "failure_impact": "Step cannot be mechanically verified or safely executed"
    },
    {
      "id": "GATE-004",
      "name": "Assumptions Documented",
      "script": "P_01260207233100000248_validate_assumptions.py",
      "phase": "core-validation",
      "depends_on": ["GATE-001"],
      "required": true,
      "timeout_sec": 120
    },
    {
      "id": "GATE-005",
      "name": "Unit Tests Pass",
      "script": "pytest",
      "phase": "testing",
      "depends_on": ["GATE-003"],
      "required": true,
      "timeout_sec": 300,
      "command": "pytest -q --junit-xml=.state/evidence/GATE-005/junit.xml"
    },
    {
      "id": "GATE-006",
      "name": "Coverage Threshold",
      "script": "pytest --cov",
      "phase": "testing",
      "depends_on": ["GATE-005"],
      "required": true,
      "timeout_sec": 300,
      "command": "pytest -q --cov=src --cov-report=json:.state/evidence/GATE-006/coverage.json",
      "checks": ["coverage >= 80%"]
    },
    {
      "id": "GATE-007",
      "name": "Automation Spec",
      "script": "validate_automation_spec.py",
