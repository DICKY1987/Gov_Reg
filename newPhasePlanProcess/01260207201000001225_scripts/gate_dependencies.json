    {
      "id": "GATE-015",
      "name": "Rollback Completeness",
      "script": "validate_rollback_completeness.py",
      "phase": "validation",
      "depends_on": ["GATE-003"],
      "required": false,
      "timeout_sec": 180
    },
    {
      "id": "GATE-016",
      "name": "Verification Completeness",
      "script": "validate_verification_completeness.py",
