      "depends_on": ["GATE-003"],
      "required": true,
      "timeout_sec": 120,
      "command": "python scripts/validate_engine_spec_separation.py",
      "purpose": "Behavior supplied by external spec/config, not step prose or custom commands"
    },
    {
      "id": "GATE-CFG-003",
      "name": "No Ad-hoc Execution",
      "script": "validate_no_adhoc_execution.py",
      "phase": "config-validation",
      "depends_on": ["GATE-003"],
      "required": true,
      "timeout_sec": 120,
      "command": "python scripts/validate_no_adhoc_execution.py",
      "purpose": "Reject bespoke commands where a registered pattern exists for the task kind"
    },
    {
      "id": "GATE-CFG-004",
      "name": "Executor Registration",
      "script": "validate_executor_registration.py",
      "phase": "config-validation",
      "depends_on": ["GATE-001"],
      "required": true,
      "timeout_sec": 60,
      "command": "python scripts/validate_executor_registration.py",
      "purpose": "Reject executor_ids not present in executor_registry"
    },
    {
      "id": "GATE-CFG-005",
      "name": "Pattern-First Gap Resolution",
      "script": "validate_pattern_first_gap_resolution.py",
      "phase": "config-validation",
      "depends_on": ["GATE-003"],
      "required": true,
      "timeout_sec": 120,
      "command": "python scripts/validate_pattern_first_gap_resolution.py",
      "purpose": "Implementation steps cannot be scheduled before PATTERN_CREATION work when no pattern exists"
    },
    {
      "id": "GATE-CFG-006",
      "name": "Behavior Binding Proof",
      "script": "validate_behavior_binding_proof.py",
      "phase": "config-validation",
      "depends_on": ["GATE-003"],
      "required": true,
      "timeout_sec": 120,
      "command": "python scripts/validate_behavior_binding_proof.py",
