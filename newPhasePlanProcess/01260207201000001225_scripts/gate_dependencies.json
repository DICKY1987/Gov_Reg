    {
      "id": "GATE-999",
      "name": "Goal Reconciliation",
      "script": "validate_goal_reconciliation.py",
      "phase": "meta-validation",
      "depends_on": ["GATE-003", "GATE-004", "GATE-005", "GATE-006"],
      "required": false,
      "timeout_sec": 180
    }
  ],
  "execution_phases": [
    {
      "phase": "pre-validation",
      "gates": ["GATE-000"],
      "description": "Ensure plan is parseable and has no placeholders"
    },
    {
