      "depends_on": ["GATE-003"],
      "required": false,
      "timeout_sec": 180
    },
    {
      "id": "GATE-017",
      "name": "Single Source of Truth",
      "script": "validate_single_source_of_truth.py",
      "phase": "validation",
      "depends_on": ["GATE-001"],
      "required": false,
      "timeout_sec": 120
    },
    {
      "id": "GATE-FILE-MUTATIONS",
      "name": "File Mutations Valid",
      "script": "P_01260207233100000290_validate_file_mutations.py",
