      "command": "python scripts/P_01260207233100000290_validate_file_mutations.py .state/planning/{plan_id}/file_mutations.json"
    },
    {
      "id": "GATE-005",
      "name": "Unit Tests Pass",
      "script": "pytest",
      "phase": "testing",
      "depends_on": ["GATE-003"],
      "required": true,
      "timeout_sec": 300,
      "command": "pytest -q --junit-xml=.state/evidence/GATE-005/junit.xml"
    },
    {
      "id": "GATE-006",
      "name": "Coverage Threshold",
      "script": "pytest --cov",
      "phase": "testing",
      "depends_on": ["GATE-005"],
      "required": true,
      "timeout_sec": 300,
      "command": "pytest -q --cov=src --cov-report=json:.state/evidence/GATE-006/coverage.json",
