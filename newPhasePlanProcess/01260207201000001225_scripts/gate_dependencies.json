  "execution_phases": [
    {
      "phase": "pre-validation",
      "gates": ["GATE-000"],
      "description": "Ensure plan is parseable and has no placeholders"
    },
    {
      "phase": "core-validation",
      "gates": ["GATE-001", "GATE-002", "GATE-003", "GATE-004"],
      "description": "Validate plan structure, gates, contracts, and assumptions"
    },
    {
      "phase": "context-validation",
      "gates": ["GATE-CONTEXT-001", "GATE-CONTEXT-002"],
      "description": "Validate referenced context artifacts and authority resolution"
    },
    {
      "phase": "artifact-validation",
      "gates": ["GATE-ARTIFACT-001", "GATE-ARTIFACT-002", "GATE-REGISTRY-001"],
      "description": "Validate artifact intent manifest, mutation declarations, and planned registry projection"
    },
    {
      "phase": "config-validation",
      "gates": ["GATE-CFG-001", "GATE-CFG-002", "GATE-CFG-003", "GATE-CFG-004", "GATE-CFG-005", "GATE-CFG-006"],
      "description": "Enforce configuration-driven development: pattern binding, executor registry, no ad-hoc execution"
    },
    {
      "phase": "mutation-validation",
      "gates": ["GATE-FILE-MUTATIONS"],
      "description": "Validate declared file mutations are deterministic and properly bounded"
    },
    {
      "phase": "testing",
      "gates": ["GATE-005", "GATE-006"],
      "description": "Run unit tests and verify coverage"
    },
    {
      "phase": "automation",
      "gates": ["GATE-007", "GATE-008", "GATE-009"],
      "description": "Validate automation configuration and generate diagrams"
    },
    {
      "phase": "wiring",
      "gates": ["GATE-010", "GATE-011", "GATE-012", "GATE-013"],
      "description": "Validate artifact flow and wiring integrity"
    },
    {
      "phase": "validation",
      "gates": ["GATE-014", "GATE-015", "GATE-016", "GATE-017"],
      "description": "Final validation checks for completeness and consistency"
    },
    {
      "phase": "reconciliation",
      "gates": ["GATE-RECON-001", "GATE-RECON-002"],
      "description": "Post-execution reconciliation of artifacts and registry against planned projections"
    },
    {
      "phase": "meta-validation",
      "gates": ["GATE-998", "GATE-999"],
      "description": "Meta-validation of automation and goal achievement"
    }
