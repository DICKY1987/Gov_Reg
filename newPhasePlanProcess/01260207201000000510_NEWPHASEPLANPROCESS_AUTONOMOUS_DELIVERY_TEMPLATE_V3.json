{
  "template_metadata": {
    "version": "3.0.0",
    "last_updated": "2026-02-03",
    "purpose": "AI-executable template with step-level contracts for mechanically verifiable project plans",
    "format": "json",
    "schema_version": "3.0.0",
    "breaking_changes": [
      "Added step-level contracts with inputs/outputs/invariants",
      "Added step_id tracking throughout pipeline",
      "Added step evidence requirements",
      "Added step-level file scoping"
    ]
  },
  "critical_constraint": {
    "name": "NO_IMPLIED_BEHAVIOR",
    "rules": [
      "Every rule, gate, and contract must be expressible as: config entry, executable command, evidence artifact path, pass/fail condition",
      "Items that cannot be expressed this way MUST be marked NOT_AUTOMATABLE and escalated to manual steps",
      "EVERY STEP must have explicit inputs/outputs/invariants defined"
    ]
  },
  "usage_instructions": {
    "steps": [
      "Read the entire template to understand the structure",
      "Fill in all sections with project-specific details",
      "Define step-level contracts for EVERY execution step",
      "Generate complete file manifest with read/write permissions for each phase AND step",
      "Generate executable commands for every gate and validation",
      "Define regex patterns for all expected outputs",
      "Create decision ledger entries for all choices made",
      "Output ONE complete plan document following this structure"
    ]
  },
  "v3_enhancements": {
    "step_level_contracts": {
      "description": "Machine-checkable contracts at individual step granularity",
      "features": [
        "inputs: explicit file/data requirements with must_exist checks",
        "outputs: guaranteed artifacts with path policies",
        "invariants: things that must remain true during step execution",
        "preconditions: checks before step starts",
        "postconditions: checks after step completes",
        "failure_modes: enumerated error codes with remediation",
        "file_scope: per-step allowed/forbidden paths"
      ],
      "enforcement": {
        "validator_command": "python scripts/validate_step_contract.py {phase} {step_id}",
        "expect_exit_code": 0,
        "evidence": ".state/evidence/{phase}/{step_id}/contract_validation.json"
      }
    },
    "step_evidence_chain": {
      "description": "Cryptographic evidence chain linking steps",
      "features": [
        "step_start_hash: SHA256 of inputs + preconditions",
        "step_end_hash: SHA256 of outputs + postconditions",
        "previous_step_hash: link to parent step",
        "chain_validation: verify unbroken evidence chain"
      ],
      "validation_command": "python scripts/validate_evidence_chain.py {phase}",
      "evidence": ".state/evidence/{phase}/evidence_chain.json"
    },
    "step_file_scoping": {
      "description": "Per-step file access control",
      "features": [
        "allowed_paths: glob patterns for permitted access",
        "forbidden_paths: glob patterns for denied access",
        "read_only_paths: paths that cannot be modified",
        "enforcement via git hooks or pre-execution checks"
      ],
      "violation_action": "abort_step",
      "validator_command": "python scripts/check_step_file_scope.py {phase} {step_id}"
    }
  },
