  "step_contracts": {
    "PH-00": {
      "STEP-001": {
        "step_id": "STEP-001",
        "purpose": "Create initial PLAN.md structure",
        "inputs": [
          {
            "id": "REPO_ROOT",
            "type": "dir",
            "required": true,
            "must_exist": true,
            "path": "."
          }
        ],
        "outputs": [
          {
            "id": "PLAN_MD",
            "type": "file",
            "path": "PLAN.md",
            "required": true,
            "content_requirements": [
              "Must contain section headers A-K",
              "Must be valid Markdown"
            ]
          }
        ],
        "invariants": [
          "No files modified except PLAN.md",
          "No code files created"
        ],
        "preconditions": [
          "test -d .",
          "test ! -f PLAN.md || echo 'WARNING: PLAN.md exists'"
        ],
        "postconditions": [
          "test -f PLAN.md",
          "grep -q '^## A\\.' PLAN.md",
          "grep -q '^## K\\.' PLAN.md"
        ],
        "file_scope": {
          "allowed_paths": [
            "PLAN.md"
          ],
          "forbidden_paths": [
            "src/**",
            "tests/**",
            "*.py",
            "*.js"
          ],
          "read_only_paths": []
        },
        "execution_policy": {
          "file_editing": {
            "default_method": "FULL_REWRITE",
            "allowed_methods": ["FULL_REWRITE", "UNIFIED_DIFF_APPLY"],
            "method_constraints": {
              "FULL_REWRITE": {
                "require_exact_after_hash": true,
                "line_endings": "PRESERVE"
              },
              "UNIFIED_DIFF_APPLY": {
                "allow_fuzz": false,
                "rejects_allowed": false,
                "require_before_after_hash": true
              }
            }
          }
        },
        "failure_modes": [
          {
            "code": "STEP-001-CREATE-FAIL",
            "meaning": "Failed to create PLAN.md",
            "remediation": "Check write permissions on repo root"
          }
        ],
        "evidence": {
          "directory": ".state/evidence/PH-00/STEP-001",
          "required_files": [
            "precondition_checks.log",
            "postcondition_checks.log",
            "file_scope_validation.json",
            "step_result.json",
            "file_mutations/*/before.sha256",
            "file_mutations/*/after.sha256",
            "file_mutations/*/diff.patch",
            "file_mutations/*/apply_log.json"
          ]
        },
        "ground_truth_level": "L1",
        "timeout_sec": 60,
        "retries": 0
      }
    },
    "PH-02": {
      "STEP-001": {
        "step_id": "STEP-001",
        "purpose": "Parse PLAN.md and extract gate requirements",
        "inputs": [
          {
            "id": "PLAN_MD",
            "type": "file",
            "required": true,
            "must_exist": true,
            "path": "PLAN.md"
          }
        ],
        "outputs": [
          {
            "id": "GATES_DRAFT",
            "type": "file",
            "path": ".state/gates_draft.yaml",
            "required": true
          }
        ],
        "invariants": [
          "PLAN.md not modified",
          "Only .state/ files created"
        ],
        "preconditions": [
          "test -f PLAN.md",
          "grep -q '^## H\\.' PLAN.md",
          "grep -q '^## I\\.' PLAN.md"
        ],
        "postconditions": [
          "test -f .state/gates_draft.yaml",
          "python -c 'import yaml; yaml.safe_load(open(\".state/gates_draft.yaml\"))'"
        ],
        "file_scope": {
          "allowed_paths": [
            ".state/**"
          ],
          "forbidden_paths": [
            "PLAN.md",
            "src/**",
            "tests/**"
          ],
          "read_only_paths": [
            "PLAN.md"
          ]
        },
        "failure_modes": [
          {
            "code": "STEP-001-PARSE-FAIL",
            "meaning": "Failed to parse PLAN.md sections",
            "remediation": "Verify PLAN.md has sections H and I"
