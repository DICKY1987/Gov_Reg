  "self_healing": {
    "enabled": true,
    "budgets": {
      "per_phase_max_attempts": 2,
      "per_gate_max_attempts": 1,
      "per_step_max_attempts": 2,
      "global_max_attempts": 10
    },
    "failure_types": [
      {
        "id": "DEP_INSTALL_FAIL",
        "allowed_actions": [
          "pip install -r requirements.txt",
          "pip install -r requirements-dev.txt"
        ],
        "max_attempts": 2,
        "abort_if": [
          "error_matches: /permission denied|access is denied|EACCES/i",
          "error_matches: /no space left on device/i"
        ],
        "commands": {
          "pip install -r requirements.txt": "pip install -r requirements.txt",
          "pip install -r requirements-dev.txt": "pip install -r requirements-dev.txt"
        },
        "step_context_required": true
      },
      {
        "id": "TEST_FAIL",
        "allowed_actions": [
          "pytest -q --last-failed",
          "pytest -q --maxfail=1"
        ],
        "max_attempts": 2,
        "abort_if": [
          "error_matches: /segmentation fault|core dumped/i",
          "error_matches: /ImportError: No module named/i"
        ],
        "commands": {
          "pytest -q --last-failed": "pytest -q --last-failed",
          "pytest -q --maxfail=1": "pytest -q --maxfail=1"
        },
        "step_context_required": true
      },
      {
        "id": "LINT_FAIL",
        "allowed_actions": [
          "python -m ruff check . --fix",
          "python -m ruff check ."
        ],
        "max_attempts": 2,
        "abort_if": [
          "error_matches: /invalid configuration|config error/i"
        ],
        "commands": {
          "python -m ruff check . --fix": "python -m ruff check . --fix",
          "python -m ruff check .": "python -m ruff check ."
        },
        "step_context_required": false
      },
      {
        "id": "TYPE_CHECK_FAIL",
        "allowed_actions": [
          "python -m mypy .",
          "python -m mypy . --ignore-missing-imports"
        ],
        "max_attempts": 2,
        "abort_if": [
          "error_matches: /mypy: error:.*config/i"
        ],
        "commands": {
          "python -m mypy .": "python -m mypy .",
          "python -m mypy . --ignore-missing-imports": "python -m mypy . --ignore-missing-imports"
        },
        "step_context_required": false
      },
      {
        "id": "INTEGRATION_TEST_FAIL",
        "allowed_actions": [
          "pytest -q -m integration",
          "pytest -q -m integration --maxfail=1"
        ],
        "max_attempts": 2,
        "abort_if": [
          "error_matches: /connection refused|timeout/i"
        ],
        "commands": {
          "pytest -q -m integration": "pytest -q -m integration",
          "pytest -q -m integration --maxfail=1": "pytest -q -m integration --maxfail=1"
        },
        "step_context_required": true
      }
    ],
    "attempt_evidence": {
      "required_files": [
        ".state/attempts/{phase}/{step_id}/{gate}/attempt_{n}/stdout.log",
        ".state/attempts/{phase}/{step_id}/{gate}/attempt_{n}/stderr.log",
        ".state/attempts/{phase}/{step_id}/{gate}/attempt_{n}/diff.patch",
        ".state/attempts/{phase}/{step_id}/{gate}/attempt_{n}/result.json"
      ],
      "required_fields_in_result_json": [
        "timestamp",
        "phase",
        "step_id",
        "gate",
        "failure_type",
        "action_taken",
        "root_cause_hypothesis",
        "change_summary",
        "verification_commands",
        "result",
        "abort_reason"
      ]
    },
    "convergence_detection": {
      "metric": "levenshtein_distance(attempt_n, attempt_n_minus_1)",
      "threshold": "< 10% change",
      "window": 2,
      "action_if_not_converging": "abort_and_escalate",
      "per_step_tracking": true
    },
    "escalation": {
      "trigger": [
        "per_phase_max_attempts exceeded",
        "per_step_max_attempts exceeded",
        "abort_if condition met",
        "not converging after 2 attempts"
      ],
      "action": [
        "write .state/escalation/{phase}_{step_id}_{gate}_escalation.json",
        "emit structured error report",
        "stop execution"
      ]
    }
  },
  "worktree_isolation": {
    "enabled": true,
    "base_ref": "main",
    "max_parallel": 3,
    "naming": {
      "pattern": ".worktrees/{phase}/{task_id}",
      "branch_pattern": "wt/{phase}/{task_id}",
      "example": ".worktrees/PH-03A/DESCRIPTIVE_NAME"
    },
    "rules": [
      "Each worktree writes ONLY inside its own root",
      "Shared artifacts written only by orchestrator after validation",
      "No direct commits to base_ref; merge via squash-merge",
      "Worktree must pass all validation gates before merge",
      "Step-level file scopes enforced within worktree"
    ],
    "lifecycle": {
      "create": {
        "command": "git worktree add {worktree_path} -b {branch_name} {base_ref}",
        "validation": [
          "test -d {worktree_path}",
          "cd {worktree_path} && git branch --show-current | grep -q '^{branch_name}$'"
        ],
        "evidence": ".state/evidence/{phase}/worktree_created.log"
      },
      "execute": {
        "working_directory": "{worktree_path}",
        "file_scope_enforcement": {
          "command": "python scripts/P_01260207233100000227_check_file_scope.py {phase_file_scope} {step_file_scope}",
          "expect_exit_code": 0
        },
        "violations_action": "abort_phase"
      },
      "validate": {
        "required_checks": [
          {
            "check": "schema_validate",
            "command": "",
            "expect_exit_code": 0
          },
          {
            "check": "step_contracts",
            "command": "python scripts/validate_all_step_contracts.py {phase}",
            "expect_exit_code": 0
          },
          {
            "check": "unit_tests",
            "command": "cd {worktree_path} && {TEST_COMMAND}",
            "expect_exit_code": 0
          },
          {
            "check": "gate_suite",
            "command": "cd {worktree_path} && {GATE_COMMAND}",
            "expect_exit_code": 0
          }
        ]
      },
      "merge": {
        "strategy": "squash",
        "conflict_policy": "abort_and_escalate",
        "command": "git checkout {base_ref} && git merge --squash {branch_name} && git commit -m '[{phase}] {summary}'",
        "precondition": [
          "all required_checks passed",
          "no uncommitted changes in {worktree_path}",
          "all step contracts validated"
        ],
        "postcondition": [
          "git log -1 --pretty=%B | grep -q '\\[{phase}\\]'"
        ],
        "evidence": ".state/evidence/{phase}/merge_result.json"
      },
      "cleanup": {
        "on_success": true,
        "on_failure": false,
        "command": "git worktree remove {worktree_path} && git branch -D {branch_name}",
        "retention_on_failure": "7 days",
        "evidence": ".state/evidence/{phase}/worktree_cleanup.log"
      }
    },
    "concurrency": {
      "limit": null,
      "scheduling_policy": "priority_queue",
      "priority_rules": [
        "Phases with more dependents have higher priority",
        "Phases in critical path have higher priority"
      ]
    }
  },
