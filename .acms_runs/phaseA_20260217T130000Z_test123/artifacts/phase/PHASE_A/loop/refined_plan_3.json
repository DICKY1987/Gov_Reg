{
  "$schema": "https://example.com/plan-schema.json",
  "plan_id": "TEST-PLAN-001",
  "schema_version": "1.0.0",
  "workstreams": [
    {
      "id": "WS-CLI",
      "summary": "Implement CLI commands",
      "tasks": [
        {
          "id": "TASK-CLI-1",
