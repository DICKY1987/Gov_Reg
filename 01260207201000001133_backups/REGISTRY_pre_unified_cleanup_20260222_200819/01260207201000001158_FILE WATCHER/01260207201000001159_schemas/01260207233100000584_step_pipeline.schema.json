{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/step_pipeline.schema.json",
  "title": "Action Taxonomy Compliant Step Pipeline Schema",
  "description": "Validates step pipeline definitions against AI-Safety Readiness Framework requirements",
  "type": "object",
  "required": [
    "version",
    "pipeline_id",
    "steps"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version (e.g., '1.0')"
    },
    "pipeline_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique pipeline identifier"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Step"
      },
      "description": "Ordered list of pipeline steps"
    }
  },
  "$defs": {
    "ActionTaxonomy": {
      "type": "string",
      "enum": [
        "artifact_resolution",
        "registry_query",
        "template_injection",
        "validation",
        "computation",
        "external_execution",
        "write_commit",
        "state_transition",
        "ledger_emission"
      ],
      "description": "Canonical 9-class action taxonomy"
    },
    "Outcome": {
      "type": "string",
      "enum": [
        "SUCCESS",
        "EXPECTED_NOOP",
        "VALIDATION_FAIL",
        "EXECUTION_ERROR",
        "SYSTEM_FAULT"
      ],
      "description": "Bounded outcome classification"
    },
    "SideEffects": {
      "type": "string",
      "enum": [
        "none",
        "append_only",
        "mutating"
      ],
      "description": "Side effect classification"
    },
    "IOPort": {
      "type": "object",
      "required": [
        "name",
        "schema_ref"
      ],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Port name"
        },
        "schema_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^#/schemas/[A-Za-z0-9_]+$",
          "description": "JSON Schema reference (e.g., '#/schemas/EventEnvelope')"
        }
      }
    },
    "Mechanics": {
      "type": "object",
      "additionalProperties": false,
      "description": "Process mechanics (NOT actions)",
      "properties": {
        "lock": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "lock_name"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "lock_name": {
              "type": "string",
              "minLength": 1
            },
            "strategy": {
              "type": "string",
              "enum": [
                "file_lock",
                "advisory_lock",
                "distributed_lock"
              ]
            }
          }
        },
        "stability_gate": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required",
            "strategy"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "strategy": {
              "type": "string",
              "enum": [
                "none",
                "mtime_quiet_period",
                "content_hash_two_pass",
                "size_stable"
              ]
            }
          }
        },
        "debounce": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "required"
          ],
          "properties": {
            "required": {
              "type": "boolean"
            },
            "strategy": {
              "type": "string",
              "enum": [
                "time_window",
                "event_coalescing",
                "idempotency_key_dedup"
              ]
            },
            "window_ms": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "Rollback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "strategy"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "strategy": {
          "type": "string",
          "enum": [
            "none",
            "snapshot_restore",
            "reverse_ops"
          ]
        },
        "snapshot_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "Ledger": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "record_kind"
      ],
      "properties": {
        "required": {
          "type": "boolean",
          "const": true,
          "description": "MUST be true per framework requirements"
        },
        "record_kind": {
          "type": "string",
          "minLength": 1,
          "description": "Type of audit record"
        },
        "intent_capture": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "required": {
              "type": "boolean"
            },
            "intent_ref": {
              "type": "string"
            }
          }
        }
      }
    },
    "McpTool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool_name",
        "input_schema_ref",
        "output_schema_ref"
      ],
      "properties": {
        "tool_name": {
          "type": "string",
          "minLength": 1,
          "description": "MCP tool name"
        },
        "input_schema_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^#/schemas/[A-Za-z0-9_]+$"
        },
        "output_schema_ref": {
          "type": "string",
          "minLength": 1,
          "pattern": "^#/schemas/[A-Za-z0-9_]+$"
        }
      }
    },
    "FastFeedback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required"
      ],
      "properties": {
        "required": {
          "type": "boolean"
        },
        "mcp_tool_name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "Step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "action",
        "description",
        "deterministic",
        "side_effects",
        "inputs",
        "outputs",
        "outcomes",
        "ledger"
      ],
      "properties": {
        "step_id": {
          "type": "string",
          "pattern": "^S[0-9]{2,3}$",
          "description": "Step ID (e.g., 'S01', 'S02')"
        },
        "action": {
          "$ref": "#/$defs/ActionTaxonomy",
          "description": "Action taxonomy class"
        },
        "description": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable step description"
        },
        "deterministic": {
          "type": "boolean",
          "description": "Is output deterministic for given input?"
        },
        "side_effects": {
          "$ref": "#/$defs/SideEffects",
          "description": "Side effect classification"
        },
        "inputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/IOPort"
          },
          "description": "Input ports"
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/IOPort"
          },
          "description": "Output ports"
        },
        "mechanics": {
          "$ref": "#/$defs/Mechanics",
          "description": "Process mechanics (optional)"
        },
        "rollback": {
          "$ref": "#/$defs/Rollback",
          "description": "Rollback strategy (required for mutating actions)"
        },
        "mcp": {
          "$ref": "#/$defs/McpTool",
          "description": "MCP tool exposure (optional)"
        },
        "fast_feedback": {
          "$ref": "#/$defs/FastFeedback",
          "description": "Fast feedback oracle (required for validation)"
        },
        "outcomes": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "success",
            "failure"
          ],
          "properties": {
            "success": {
              "$ref": "#/$defs/Outcome"
            },
            "failure": {
              "$ref": "#/$defs/Outcome"
            }
          },
          "description": "Outcome classification for success/failure branches"
        },
        "ledger": {
          "$ref": "#/$defs/Ledger",
          "description": "Ledger emission (MANDATORY)"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "action": {
                "const": "write_commit"
              }
            }
          },
          "then": {
            "properties": {
              "side_effects": {
                "const": "mutating"
              }
            },
            "required": [
              "rollback",
              "mechanics"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "external_execution"
              }
            }
          },
          "then": {
            "properties": {
              "side_effects": {
                "const": "mutating"
              },
              "deterministic": {
                "const": false
              }
            },
            "required": [
              "rollback"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "validation"
              }
            }
          },
          "then": {
            "properties": {
              "side_effects": {
                "const": "none"
              },
              "deterministic": {
                "const": true
              }
            },
            "required": [
              "fast_feedback"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "computation"
              }
            }
          },
          "then": {
            "properties": {
              "side_effects": {
                "const": "none"
              },
              "deterministic": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "action": {
                "const": "ledger_emission"
              }
            }
          },
          "then": {
            "properties": {
              "side_effects": {
                "enum": [
                  "append_only",
                  "none"
                ]
              }
            }
          }
        }
      ]
    }
  },
  "file_id": "01260207233100000584"
}