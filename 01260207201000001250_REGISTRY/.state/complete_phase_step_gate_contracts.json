{
  "phase_contracts": {
    "PH-01": {
      "purpose": "Source Inventory and Issue Harvest - Extract and normalize all issues",
      "inputs": [
        {"id": "REG_AUTO_PLAN_TXT", "type": "file", "required": true, "must_exist": true, "path": "REG_AUTO_PLAN.txt"},
        {"id": "ALIGNMENT_ASSESSMENT", "type": "file", "required": true, "must_exist": true, "path": "ChatGPT-Automation Alignment Assessment.md"},
        {"id": "RESILIENT_RAINBOW", "type": "file", "required": true, "must_exist": true, "path": "resilient-skipping-rainbow.md"}
      ],
      "outputs": [
        {"id": "NORMALIZED_ISSUES", "type": "file", "path": ".state/issues/normalized_issues.json", "required": true},
        {"id": "COMPONENT_INVENTORY", "type": "file", "path": ".state/issues/component_inventory.json", "required": true},
        {"id": "CONTRACT_TAXONOMY", "type": "file", "path": ".state/issues/contract_taxonomy.json", "required": true}
      ],
      "invariants": ["No source documents modified", "Only .state/issues/ files created"],
      "preconditions": ["All source documents exist and are readable"],
      "postconditions": [
        "test -f .state/issues/normalized_issues.json",
        "test -f .state/issues/component_inventory.json",
        "test -f .state/issues/contract_taxonomy.json",
        "jq '.metadata.total_issues' .state/issues/normalized_issues.json | grep -q 19"
      ],
      "failure_modes": [
        {"code": "PH-01-SOURCE-MISSING", "meaning": "Source document not found", "remediation": "Verify file paths and retry"},
        {"code": "PH-01-PARSE-FAIL", "meaning": "Failed to parse source content", "remediation": "Check file encoding and format"}
      ],
      "steps": ["STEP-001", "STEP-002", "STEP-003"]
    },
    "PH-02": {
      "purpose": "Contract-Gap Matrix Authoring - Convert issues to framework-native matrix",
      "inputs": [
        {"id": "NORMALIZED_ISSUES", "type": "file", "required": true, "must_exist": true, "path": ".state/issues/normalized_issues.json"},
        {"id": "CONTRACT_TAXONOMY", "type": "file", "required": true, "must_exist": true, "path": ".state/issues/contract_taxonomy.json"}
      ],
      "outputs": [
        {"id": "MATRIX_MD", "type": "file", "path": "CONTRACT_GAP_MATRIX.md", "required": true},
        {"id": "MATRIX_JSON", "type": "file", "path": ".state/matrix/contract_gap_matrix.json", "required": true}
      ],
      "invariants": ["Every matrix row has all 11 required fields", "All issues use framework-native language"],
      "preconditions": ["Normalized issues exist with 19 entries"],
      "postconditions": [
        "test -f CONTRACT_GAP_MATRIX.md",
        "test -f .state/matrix/contract_gap_matrix.json",
        "jq '.metadata.total_rows' .state/matrix/contract_gap_matrix.json | grep -q 19"
      ],
      "failure_modes": [
        {"code": "PH-02-INCOMPLETE-ROW", "meaning": "Matrix row missing required field", "remediation": "Complete all 11 fields for each row"},
        {"code": "PH-02-SCRIPT-LANG", "meaning": "Script-centric phrasing remains", "remediation": "Convert to framework-native language"}
      ],
      "steps": ["STEP-001", "STEP-002", "STEP-003", "STEP-004"]
    },
    "PH-03": {
      "purpose": "ProgramSpec Mapping - Map matrix rows to ProgramSpec fields",
      "inputs": [
        {"id": "MATRIX_JSON", "type": "file", "required": true, "must_exist": true, "path": ".state/matrix/contract_gap_matrix.json"}
      ],
      "outputs": [
        {"id": "PROGRAMSPEC_MAPPING", "type": "file", "path": ".state/programspec/programspec_mapping.json", "required": true},
        {"id": "RUNNER_CAPABILITY_MAP", "type": "file", "path": ".state/programspec/runner_capability_map.json", "required": true}
      ],
      "invariants": ["Every matrix row maps to at least one ProgramSpec field"],
      "preconditions": ["Matrix complete with 19 rows"],
      "postconditions": [
        "test -f .state/programspec/programspec_mapping.json",
        "test -f .state/programspec/runner_capability_map.json",
        "jq '.validation.all_issues_mapped' .state/programspec/programspec_mapping.json | grep -q true"
      ],
      "failure_modes": [
        {"code": "PH-03-UNMAPPED", "meaning": "Issue not mapped to any ProgramSpec field", "remediation": "Assign at least one spec field per issue"}
      ],
      "steps": ["STEP-001", "STEP-002", "STEP-003"]
    },
    "PH-04": {
      "purpose": "Remediation Synthesis - Organize fixes by dependency order",
      "inputs": [
        {"id": "MATRIX_JSON", "type": "file", "required": true, "must_exist": true, "path": ".state/matrix/contract_gap_matrix.json"},
        {"id": "RUNNER_MAP", "type": "file", "required": true, "must_exist": true, "path": ".state/programspec/runner_capability_map.json"}
      ],
      "outputs": [
        {"id": "REMEDIATION_PLAN", "type": "file", "path": ".state/remediation/remediation_plan.json", "required": true}
      ],
      "invariants": ["Remediation respects dependency order from enforcement_priority_order"],
      "preconditions": ["Matrix and runner map complete"],
      "postconditions": [
        "test -f .state/remediation/remediation_plan.json",
        "jq '.remediation_phases | length' .state/remediation/remediation_plan.json | grep -q 6"
      ],
      "failure_modes": [
        {"code": "PH-04-CYCLE-DETECTED", "meaning": "Circular dependency in remediation order", "remediation": "Break cycle by deferring one issue"}
      ],
      "steps": ["STEP-001", "STEP-002", "STEP-003", "STEP-004"]
    },
    "PH-05": {
      "purpose": "Gate Generation - Create deterministic validation gates",
      "inputs": [
        {"id": "MATRIX_JSON", "type": "file", "required": true, "must_exist": true, "path": ".state/matrix/contract_gap_matrix.json"}
      ],
      "outputs": [
        {"id": "GATES_SPEC", "type": "file", "path": ".state/gates/gates_spec.json", "required": true}
      ],
      "invariants": ["Every gate has command, timeout, retries, expect/forbid regex, evidence"],
      "preconditions": ["Matrix complete with verification_test for all rows"],
      "postconditions": [
        "test -f .state/gates/gates_spec.json",
        "jq '.gates | length' .state/gates/gates_spec.json | grep -q 6"
      ],
      "failure_modes": [
        {"code": "PH-05-VAGUE-TEST", "meaning": "Verification test not deterministic", "remediation": "Add pass/fail criteria to test"}
      ],
      "steps": ["STEP-001", "STEP-002"]
    },
    "PH-06": {
      "purpose": "Plan Assembly - Assemble final template-native plan",
      "inputs": [
        {"id": "ALL_ARTIFACTS", "type": "dir", "required": true, "must_exist": true, "path": ".state/"},
        {"id": "MATRIX_MD", "type": "file", "required": true, "must_exist": true, "path": "CONTRACT_GAP_MATRIX.md"},
        {"id": "TEMPLATE", "type": "file", "required": true, "must_exist": true, "path": "C:\\Users\\richg\\Gov_Reg\\newPhasePlanProcess\\01260207201000000510_NEWPHASEPLANPROCESS_AUTONOMOUS_DELIVERY_TEMPLATE_V3.json"}
      ],
      "outputs": [
        {"id": "FINAL_PLAN", "type": "file", "path": "REG_AUTO_PLAN_REWRITTEN_TEMPLATE_NATIVE.json", "required": true}
      ],
      "invariants": ["Final plan validates against template schema", "All sections present"],
      "preconditions": ["All phase artifacts generated and validated"],
      "postconditions": [
        "test -f REG_AUTO_PLAN_REWRITTEN_TEMPLATE_NATIVE.json",
        "jq '.template_metadata.version' REG_AUTO_PLAN_REWRITTEN_TEMPLATE_NATIVE.json | grep -q '3.0.0'"
      ],
      "failure_modes": [
        {"code": "PH-06-NON-CONFORMANT", "meaning": "Plan does not match template structure", "remediation": "Add missing template sections"}
      ],
      "steps": ["STEP-001", "STEP-002"]
    }
  },
  "step_contracts": {
    "PH-01": {
      "STEP-001": {
        "step_id": "STEP-001",
        "purpose": "Parse source documents and extract raw issues",
        "command": "python scripts/extract_issues.py --reg-auto REG_AUTO_PLAN.txt --alignment 'ChatGPT-Automation Alignment Assessment.md' --rainbow resilient-skipping-rainbow.md --out .state/issues/normalized_issues.json",
        "inputs": [{"id": "SOURCE_DOCS", "type": "file", "required": true, "path": "REG_AUTO_PLAN.txt"}],
        "outputs": [{"id": "NORMALIZED", "type": "file", "path": ".state/issues/normalized_issues.json", "required": true}],
        "invariants": ["No source files modified"],
        "preconditions": ["test -f REG_AUTO_PLAN.txt"],
        "postconditions": ["test -f .state/issues/normalized_issues.json"],
        "file_scope": {
          "allowed_paths": [".state/issues/**"],
          "forbidden_paths": ["src/**", "scripts/**"],
          "read_only_paths": ["REG_AUTO_PLAN.txt", "ChatGPT-Automation Alignment Assessment.md", "resilient-skipping-rainbow.md"]
        },
        "failure_modes": [
          {"code": "STEP-001-PARSE", "meaning": "Parse error in source", "remediation": "Check file format"}
        ],
        "evidence": {
          "directory": ".state/evidence/PH-01/STEP-001",
          "required_files": ["precondition_checks.log", "postcondition_checks.log", "step_result.json"]
        },
        "ground_truth_level": "L1",
        "timeout_sec": 180,
        "retries": 1
      },
      "STEP-002": {
        "step_id": "STEP-002",
        "purpose": "Build component inventory from scripts",
        "command": "python scripts/build_component_inventory.py --scripts-dir scripts/ --out .state/issues/component_inventory.json",
        "inputs": [{"id": "SCRIPTS_DIR", "type": "dir", "required": true, "path": "scripts/"}],
        "outputs": [{"id": "INVENTORY", "type": "file", "path": ".state/issues/component_inventory.json", "required": true}],
        "invariants": ["No scripts modified"],
        "preconditions": ["test -d scripts/"],
        "postconditions": ["test -f .state/issues/component_inventory.json", "jq '.metadata.total_scripts' .state/issues/component_inventory.json | grep -q 19"],
        "file_scope": {
          "allowed_paths": [".state/issues/**"],
          "forbidden_paths": ["scripts/**"],
          "read_only_paths": ["scripts/**"]
        },
        "failure_modes": [
          {"code": "STEP-002-COUNT", "meaning": "Script count mismatch", "remediation": "Verify scripts directory"}
        ],
        "evidence": {
          "directory": ".state/evidence/PH-01/STEP-002",
          "required_files": ["precondition_checks.log", "postcondition_checks.log", "step_result.json"]
        },
        "ground_truth_level": "L1",
        "timeout_sec": 120,
        "retries": 0
      },
      "STEP-003": {
        "step_id": "STEP-003",
        "purpose": "Generate contract taxonomy from standard types",
        "command": "python scripts/generate_taxonomy.py --contracts input_contract,identity_contract,output_result_envelope_contract,evidence_contract,pass_fail_criteria_contract,mutation_safety_contract,rollback_contract,fingerprint_idempotency_contract --out .state/issues/contract_taxonomy.json",
        "inputs": [],
        "outputs": [{"id": "TAXONOMY", "type": "file", "path": ".state/issues/contract_taxonomy.json", "required": true}],
        "invariants": ["Exactly 8 standard contract types defined"],
        "preconditions": [],
        "postconditions": ["test -f .state/issues/contract_taxonomy.json", "jq '.standard_contract_types | length' .state/issues/contract_taxonomy.json | grep -q 8"],
        "file_scope": {
          "allowed_paths": [".state/issues/**"],
          "forbidden_paths": ["src/**", "scripts/**"],
          "read_only_paths": []
        },
        "failure_modes": [
          {"code": "STEP-003-TYPE-MISSING", "meaning": "Standard contract type missing", "remediation": "Add missing type"}
        ],
        "evidence": {
          "directory": ".state/evidence/PH-01/STEP-003",
          "required_files": ["precondition_checks.log", "postcondition_checks.log", "step_result.json"]
        },
        "ground_truth_level": "L1",
        "timeout_sec": 60,
        "retries": 0
      }
    },
    "PH-02": {
      "STEP-001": {
        "step_id": "STEP-001",
        "purpose": "Convert normalized issues to matrix rows",
        "command": "python scripts/build_contract_gap_matrix.py --issues .state/issues/normalized_issues.json --taxonomy .state/issues/contract_taxonomy.json --out CONTRACT_GAP_MATRIX.md --json .state/matrix/contract_gap_matrix.json",
        "inputs": [
          {"id": "ISSUES", "type": "file", "required": true, "path": ".state/issues/normalized_issues.json"},
          {"id": "TAXONOMY", "type": "file", "required": true, "path": ".state/issues/contract_taxonomy.json"}
        ],
        "outputs": [
          {"id": "MATRIX_MD", "type": "file", "path": "CONTRACT_GAP_MATRIX.md", "required": true},
          {"id": "MATRIX_JSON", "type": "file", "path": ".state/matrix/contract_gap_matrix.json", "required": true}
        ],
        "invariants": ["All 11 required fields populated for each row", "Framework-native language only"],
        "preconditions": ["test -f .state/issues/normalized_issues.json"],
        "postconditions": ["test -f CONTRACT_GAP_MATRIX.md", "test -f .state/matrix/contract_gap_matrix.json"],
        "file_scope": {
          "allowed_paths": [".state/matrix/**", "CONTRACT_GAP_MATRIX.md"],
          "forbidden_paths": ["src/**", "scripts/**"],
          "read_only_paths": [".state/issues/**"]
        },
        "failure_modes": [
          {"code": "STEP-001-FIELD-EMPTY", "meaning": "Required field empty", "remediation": "Complete all fields"}
        ],
        "evidence": {
          "directory": ".state/evidence/PH-02/STEP-001",
          "required_files": ["precondition_checks.log", "postcondition_checks.log", "step_result.json", "matrix_generation.log"]
        },
        "ground_truth_level": "L2",
        "timeout_sec": 300,
        "retries": 0
      },
      "STEP-002": {
        "step_id": "STEP-002",
        "purpose": "Validate matrix completeness",
        "command": "python scripts/validate_matrix_completeness.py --matrix CONTRACT_GAP_MATRIX.md --json .state/matrix/contract_gap_matrix.json",
        "inputs": [{"id": "MATRIX", "type": "file", "required": true, "path": "CONTRACT_GAP_MATRIX.md"}],
        "outputs": [],
        "invariants": ["No empty fields", "All contract types from taxonomy"],
        "preconditions": ["test -f CONTRACT_GAP_MATRIX.md"],
        "postconditions": ["python scripts/validate_matrix_completeness.py --matrix CONTRACT_GAP_MATRIX.md --json .state/matrix/contract_gap_matrix.json | grep -q 'matrix complete: true'"],
        "file_scope": {
          "allowed_paths": [".state/evidence/**"],
          "forbidden_paths": ["CONTRACT_GAP_MATRIX.md", "src/**", "scripts/**"],
          "read_only_paths": ["CONTRACT_GAP_MATRIX.md", ".state/matrix/**"]
        },
        "failure_modes": [
          {"code": "STEP-002-INCOMPLETE", "meaning": "Matrix validation failed", "remediation": "Fix matrix rows"}
        ],
        "evidence": {
          "directory": ".state/evidence/PH-02/STEP-002",
          "required_files": ["validation_report.json", "step_result.json"]
        },
        "ground_truth_level": "L2",
        "timeout_sec": 120,
        "retries": 0
      },
      "STEP-003": {
        "step_id": "STEP-003",
        "purpose": "Convert script-centric language to framework-native",
        "command": "python scripts/convert_language.py --matrix .state/matrix/contract_gap_matrix.json --patterns script_bug=executor_output_envelope_validation,fix_script=runner_must_enforce --out .state/matrix/contract_gap_matrix.json",
        "inputs": [{"id": "MATRIX", "type": "file", "required": true, "path": ".state/matrix/contract_gap_matrix.json"}],
        "outputs": [{"id": "CONVERTED", "type": "file", "path": ".state/matrix/contract_gap_matrix.json", "required": true}],
        "invariants": ["Zero script-centric phrases remaining"],
        "preconditions": ["test -f .state/matrix/contract_gap_matrix.json"],
        "postconditions": ["python scripts/validate_language.py --matrix .state/matrix/contract_gap_matrix.json | grep -q 'framework_native: true'"],
        "file_scope": {
          "allowed_paths": [".state/matrix/**", ".state/evidence/**"],
          "forbidden_paths": ["src/**", "scripts/**"],
          "read_only_paths": []
        },
        "failure_modes": [
          {"code": "STEP-003-SCRIPT-LANG", "meaning": "Script-centric language remains", "remediation": "Apply conversion patterns"}
        ],
        "evidence": {
          "directory": ".state/evidence/PH-02/STEP-003",
          "required_files": ["language_conversion.log", "step_result.json"]
        },
        "ground_truth_level": "L2",
        "timeout_sec": 180,
        "retries": 1
      },
      "STEP-004": {
        "step_id": "STEP-004",
        "purpose": "Regenerate markdown from validated JSON",
        "command": "python scripts/json_to_markdown_matrix.py --json .state/matrix/contract_gap_matrix.json --out CONTRACT_GAP_MATRIX.md",
        "inputs": [{"id": "MATRIX_JSON", "type": "file", "required": true, "path": ".state/matrix/contract_gap_matrix.json"}],
        "outputs": [{"id": "MATRIX_MD", "type": "file", "path": "CONTRACT_GAP_MATRIX.md", "required": true}],
        "invariants": ["Markdown synchronized with JSON"],
        "preconditions": ["test -f .state/matrix/contract_gap_matrix.json"],
        "postconditions": ["test -f CONTRACT_GAP_MATRIX.md", "grep -q 'FCA-001' CONTRACT_GAP_MATRIX.md"],
        "file_scope": {
          "allowed_paths": ["CONTRACT_GAP_MATRIX.md", ".state/evidence/**"],
          "forbidden_paths": ["src/**", "scripts/**"],
          "read_only_paths": [".state/matrix/**"]
        },
        "failure_modes": [
          {"code": "STEP-004-SYNC-FAIL", "meaning": "MD/JSON mismatch", "remediation": "Regenerate from JSON"}
        ],
        "evidence": {
          "directory": ".state/evidence/PH-02/STEP-004",
          "required_files": ["md_generation.log", "step_result.json"]
        },
        "ground_truth_level": "L1",
        "timeout_sec": 90,
        "retries": 0
      }
    }
  },
  "validation_gates": [
    {
      "gate_id": "GATE-001-SOURCE-COMPLETE",
      "phase": "PH-01",
      "step_id": null,
      "purpose": "Verify all source issues extracted and normalized",
      "command": "python scripts/validate_source_extraction.py --issues .state/issues/normalized_issues.json --expected-count 19",
      "timeout_sec": 60,
      "retries": 0,
      "expect_exit_code": 0,
      "expect_stdout_regex": ["/all source issues extracted: true/", "/issue count: 19/"],
      "forbid_stdout_regex": ["/error/i", "/missing/i"],
      "expect_files": [
        {"path": ".state/issues/normalized_issues.json", "content_regex": ["/\"total_issues\": 19/"]},
        {"path": ".state/issues/component_inventory.json", "content_regex": ["/\"total_scripts\": 19/"]},
        {"path": ".state/issues/contract_taxonomy.json", "content_regex": ["/input_contract/"]}
      ],
      "evidence": ".state/evidence/PH-01/GATE-001"
    },
    {
      "gate_id": "GATE-002-MATRIX-COMPLETE",
      "phase": "PH-02",
      "step_id": "STEP-001",
      "purpose": "Verify contract-gap matrix has all required fields populated",
      "command": "python scripts/validate_matrix_completeness.py --matrix CONTRACT_GAP_MATRIX.md --json .state/matrix/contract_gap_matrix.json",
      "timeout_sec": 120,
      "retries": 0,
      "expect_exit_code": 0,
      "expect_stdout_regex": [
        "/matrix complete: true/",
        "/all rows have framework_category: true/",
        "/all rows have broken_contract: true/",
        "/all rows have required_runner_capability: true/",
        "/all rows have required_spec_fields: true/",
        "/all rows have evidence_required: true/",
        "/all rows have remediation_type: true/",
        "/all rows have verification_test: true/"
      ],
      "forbid_stdout_regex": ["/empty field/i", "/missing/i"],
      "expect_files": [
        {"path": "CONTRACT_GAP_MATRIX.md", "content_regex": ["/\\| FCA-001 \\|/"]},
        {"path": ".state/matrix/contract_gap_matrix.json", "content_regex": ["/\"total_rows\": 19/"]}
      ],
      "evidence": ".state/evidence/PH-02/GATE-002"
    },
    {
      "gate_id": "GATE-003-MAPPING-COMPLETE",
      "phase": "PH-03",
      "step_id": "STEP-001",
      "purpose": "Verify every matrix row maps to at least one ProgramSpec field",
      "command": "python scripts/validate_programspec_mapping.py --matrix .state/matrix/contract_gap_matrix.json --mapping .state/programspec/programspec_mapping.json",
      "timeout_sec": 90,
      "retries": 0,
      "expect_exit_code": 0,
      "expect_stdout_regex": ["/mapping complete: true/", "/all issues mapped: true/"],
      "forbid_stdout_regex": ["/unmapped/i"],
      "expect_files": [
        {"path": ".state/programspec/programspec_mapping.json", "content_regex": ["/\"all_issues_mapped\": true/"]}
      ],
      "evidence": ".state/evidence/PH-03/GATE-003"
    },
    {
      "gate_id": "GATE-004-STEP-CONTRACTS-COMPLETE",
      "phase": "PH-04",
      "step_id": null,
      "purpose": "Verify all steps have complete contracts",
      "command": "python scripts/validate_step_contracts.py --plan REG_AUTO_PLAN_REWRITTEN_TEMPLATE_NATIVE.json",
      "timeout_sec": 180,
      "retries": 0,
      "expect_exit_code": 0,
      "expect_stdout_regex": ["/step contracts complete: true/"],
      "forbid_stdout_regex": ["/incomplete step/i"],
      "expect_files": [
        {"path": "REG_AUTO_PLAN_REWRITTEN_TEMPLATE_NATIVE.json", "content_regex": ["/\"preconditions\":/", "/\"postconditions\":/"]}
      ],
      "evidence": ".state/evidence/PH-04/GATE-004"
    },
    {
      "gate_id": "GATE-005-VERIFICATION-DEFINED",
      "phase": "PH-05",
      "step_id": "STEP-001",
      "purpose": "Verify every matrix row has deterministic verification test",
      "command": "python scripts/validate_verification_tests.py --matrix .state/matrix/contract_gap_matrix.json",
      "timeout_sec": 90,
      "retries": 0,
      "expect_exit_code": 0,
      "expect_stdout_regex": ["/all rows have verification_test: true/", "/all tests deterministic: true/"],
      "forbid_stdout_regex": ["/vague/i"],
      "expect_files": [
        {"path": ".state/gates/gates_spec.json", "content_regex": ["/\"gate_id\":/"]}
      ],
      "evidence": ".state/evidence/PH-05/GATE-005"
    },
    {
      "gate_id": "GATE-006-TEMPLATE-CONFORMANT",
      "phase": "PH-06",
      "step_id": "STEP-002",
      "purpose": "Verify final plan conforms to template structure",
      "command": "python scripts/validate_template_conformance.py --plan REG_AUTO_PLAN_REWRITTEN_TEMPLATE_NATIVE.json --template C:\\Users\\richg\\Gov_Reg\\newPhasePlanProcess\\01260207201000000510_NEWPHASEPLANPROCESS_AUTONOMOUS_DELIVERY_TEMPLATE_V3.json",
      "timeout_sec": 120,
      "retries": 0,
      "expect_exit_code": 0,
      "expect_stdout_regex": ["/template conformant: true/"],
      "forbid_stdout_regex": ["/non-conformant/i"],
      "expect_files": [
        {"path": "REG_AUTO_PLAN_REWRITTEN_TEMPLATE_NATIVE.json", "content_regex": ["/\"template_metadata\":/", "/\"phase_contracts\":/"]}
      ],
      "evidence": ".state/evidence/PH-06/GATE-006"
    }
  ],
  "ground_truth_levels": {
    "enum": {
      "L0": "No verification (documentation-only)",
      "L1": "Static checks (lint/format/schema parse)",
      "L2": "Unit tests (fast, isolated)",
      "L3": "Integration tests (multi-component)",
      "L4": "End-to-end / workflow simulation"
    },
    "required_by_phase": {
      "PH-01": "L1",
      "PH-02": "L2",
      "PH-03": "L2",
      "PH-04": "L2",
      "PH-05": "L2",
      "PH-06": "L2"
    },
    "enforcement": {
      "rule": "Phase CANNOT transition to next phase unless minimum level passed for ALL steps",
      "validator_command": "python scripts/validate_ground_truth.py {phase} {min_level}",
      "expect_exit_code": 0
