{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://acms.gov/schemas/worktree_execution_report.schema.json",
  "title": "Worktree Execution Report",
  "description": "Schema for individual workstream execution report in isolated worktree",
  "type": "object",
  "required": ["workstream_id", "worktree_path", "exit_code", "touched_files"],
  "properties": {
    "workstream_id": {
      "type": "string",
      "pattern": "^ws_[a-zA-Z0-9_-]+$"
    },
    "worktree_path": {
      "type": "string",
      "description": "Absolute path to the worktree"
    },
    "exit_code": {
      "type": "integer",
      "description": "Exit code from workstream execution (0=success)"
    },
    "touched_files": {
      "type": "array",
      "description": "Files actually modified during execution",
      "items": {
        "type": "string"
      }
    },
    "patches": {
      "type": "array",
      "description": "Unified diff patches generated from workstream changes",
      "items": {
        "type": "object",
        "required": ["file_path", "patch_content"],
        "properties": {
          "file_path": {
            "type": "string"
          },
          "patch_content": {
            "type": "string",
            "description": "Unified diff format patch"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 hash of patch content"
          }
        }
      }
    },
    "evidence_path": {
      "type": "string",
      "description": "Path to evidence bundle for this workstream"
    },
    "execution_metadata": {
      "type": "object",
      "properties": {
        "start_time": {
          "type": "string",
          "format": "date-time"
        },
        "end_time": {
          "type": "string",
          "format": "date-time"
        },
        "duration_seconds": {
          "type": "number",
          "minimum": 0
        },
        "base_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        }
      }
    },
    "violations": {
      "type": "array",
      "description": "Write manifest violations detected",
      "items": {
        "type": "object",
        "required": ["violation_type", "file_path"],
        "properties": {
          "violation_type": {
            "type": "string",
            "enum": ["undeclared_write", "forbidden_read", "exclusive_lock_violation"]
          },
          "file_path": {
            "type": "string"
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning"]
          }
        }
      }
    },
    "stdout_log": {
      "type": "string",
      "description": "Captured stdout from execution"
    },
    "stderr_log": {
      "type": "string",
      "description": "Captured stderr from execution"
    }
  }
}
