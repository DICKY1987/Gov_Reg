{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://acms.gov/schemas/evidence_bundle.schema.json",
  "title": "Evidence Bundle",
  "description": "Schema for workstream execution evidence bundle",
  "type": "object",
  "required": ["run_id", "workstream_id", "gate_results", "artifacts", "hash_manifest"],
  "properties": {
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-zA-Z0-9_-]+$",
      "description": "Unique identifier for the execution run"
    },
    "workstream_id": {
      "type": "string",
      "pattern": "^ws_[a-zA-Z0-9_-]+$",
      "description": "Workstream that generated this evidence"
    },
    "gate_results": {
      "type": "array",
      "description": "Results from all gate validations",
      "items": {
        "type": "object",
        "required": ["gate_id", "passed", "timestamp"],
        "properties": {
          "gate_id": {
            "type": "string",
            "pattern": "^GATE-PWE-\\d{3}$",
            "description": "Gate identifier (GATE-PWE-001 through GATE-PWE-012)"
          },
          "passed": {
            "type": "boolean"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time"
          },
          "evidence_path": {
            "type": "string"
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "artifacts": {
      "type": "array",
      "description": "Artifacts produced by workstream execution",
      "items": {
        "type": "object",
        "required": ["artifact_type", "path", "sha256"],
        "properties": {
          "artifact_type": {
            "type": "string",
            "enum": [
              "patch",
              "execution_log",
              "write_manifest",
              "conflict_graph",
              "worktree_report",
              "integration_report",
              "determinism_report"
            ]
          },
          "path": {
            "type": "string",
            "description": "Relative path to artifact"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$",
            "description": "SHA-256 hash of artifact"
          },
          "size_bytes": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "hash_manifest": {
      "type": "object",
      "description": "Map of file paths to SHA-256 hashes for verification",
      "patternProperties": {
        ".*": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "bundle_metadata": {
      "type": "object",
      "properties": {
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "bundle_version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$",
          "default": "1.0.0"
        },
        "total_artifacts": {
          "type": "integer",
          "minimum": 0
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
