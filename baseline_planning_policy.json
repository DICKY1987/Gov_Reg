{
  "policy_id": "POLICY_20260218T120000Z_abc12345",
  "version": "1.0.0",
  "required_plan_sections": [
    "plan_id",
    "version",
    "objective",
    "scope",
    "assumptions",
    "constraints",
    "workstreams",
    "deliverables",
    "acceptance_criteria",
    "risks",
    "dependencies",
    "gates",
    "declared_new_artifacts",
    "metadata"
  ],
  "defect_taxonomy": {
    "hard_defect_rules": [
      "COMP-001",
      "COMP-002",
      "SCHEMA-001",
      "PATTERN-*",
      "REF-001"
    ],
    "soft_defect_rules": [
      "AC-001",
      "AC-002",
      "STYLE-*",
      "OPT-*"
    ]
  },
  "rule_catalog": [
    {
      "rule_code": "COMP-001",
      "severity": "CRITICAL",
      "description": "Required plan section is missing",
      "detection_method": "DETERMINISTIC",
      "remediation_guidance": "Add the missing section to plan structure"
    },
    {
      "rule_code": "COMP-002",
      "severity": "HIGH",
      "description": "Required plan section is empty",
      "detection_method": "DETERMINISTIC",
      "remediation_guidance": "Populate the section with required content"
    },
    {
      "rule_code": "SCHEMA-001",
      "severity": "CRITICAL",
      "description": "Plan violates PLAN.schema.json",
      "detection_method": "DETERMINISTIC",
      "remediation_guidance": "Fix schema validation errors"
    },
    {
      "rule_code": "AC-001",
      "severity": "MEDIUM",
      "description": "Acceptance criterion lacks measurement method",
      "detection_method": "DETERMINISTIC",
      "remediation_guidance": "Add specific measurement command or metric"
    },
    {
      "rule_code": "AC-002",
      "severity": "MEDIUM",
      "description": "Acceptance criterion lacks target value",
      "detection_method": "DETERMINISTIC",
      "remediation_guidance": "Add measurable target value"
    }
  ],
  "iteration_limits": {
    "max_iterations": 5,
    "hard_defect_timeout": 3,
    "soft_defect_improvement_threshold": 0.05
  },
  "critic_mode": "DETERMINISTIC",
  "forbidden_patterns": [
    {
      "pattern_id": "VAGUE-001",
      "regex": "\\b(maybe|perhaps|possibly|might)\\b",
      "reason": "Vague language reduces determinism"
    },
    {
      "pattern_id": "VAGUE-002",
      "regex": "\\b(TBD|TODO|FIXME)\\b",
      "reason": "Incomplete planning artifacts"
    }
  ],
  "allowed_patch_operations": [
    "add",
    "remove",
    "replace",
    "move",
    "copy",
    "test"
  ]
}
