    "write_target": "project_field.Phase",
    "decision_artifacts": [
      "reports/phase_advancement_report.json",
      "reports/phase_transition_decision.json"
    ],
    "level_triggered": true,
    "event_triggers": [
      "TRIG-PR-CLOSED-MERGED",
      "TRIG-CHECK-COMPLETE",
      "TRIG-ISSUE-CLOSED",
      "TRIG-SCHEDULED-RECONCILIATION"
    ],
    "composite_exit_criteria": [
      "all_required_phase_gates_pass == true",
      "all_step_issues_in_phase_closed == true",
      "all_required_evidence_states_sealed == true",
      "all_required_milestones_for_phase_complete == true OR phase_has_no_milestone_requirements",
      "no_open_blocking_subissues == true",
      "no_unresolved_violation_drift_for_phase == true"
    ],
    "decision_actions": {
      "if_true": [
        "advance_phase_to_next_option_id",
        "write_decision_artifacts",
        "update_determinism_state_to_reconciled"
      ],
      "if_false": [
        "write_decision_artifacts",
        "set_gate_GH_PHASE_ADVANCE_APPLIED_OR_EXPLICITLY_BLOCKED_to_blocked"
      ]
    }
  },
  "pipeline_bridge": {
    "generic_pipeline_to_github_mapping": [
      {
        "pipeline_stage": "Trigger",
        "github_transition": "issue_created_or_project_item_detected"
      },
      {
        "pipeline_stage": "Ingest",
        "github_transition": "project_item_added"
      },
      {
        "pipeline_stage": "Stabilize",
        "github_transition": "determinism_state_pending"
      },
      {
        "pipeline_stage": "Classify",
        "github_transition": "labels_or_fields_routed"
      },
      {
        "pipeline_stage": "Identify",
        "github_transition": "StepID_bound"
      },
      {
        "pipeline_stage": "Lock",
        "github_transition": "issue_assigned_and_status_in_progress"
      },
      {
        "pipeline_stage": "ValidatePre",
        "github_transition": "preflight_checks_running"
      },
      {
        "pipeline_stage": "Process",
        "github_transition": "branch_and_pr_created"
      },
      {
        "pipeline_stage": "Generate",
        "github_transition": "code_changes_present_in_pr"
      },
      {
        "pipeline_stage": "Commit",
        "github_transition": "commit_and_pr_update"
      },
      {
        "pipeline_stage": "ValidatePost",
        "github_transition": "gate_status_passed_or_failed"
      },
      {
        "pipeline_stage": "Rollback",
        "github_transition": "pr_blocked_or_reverted_and_evidence_written"
      },
      {
        "pipeline_stage": "Complete",
        "github_transition": "issue_closed_status_done_auto_archive_eligible"
      }
    ]
  },
  "process_phases": [
    {
      "phase_id": "PROC-0",
      "name": "Bootstrap",
      "trigger_ids": [
        "TRIG-MANUAL-BOOTSTRAP",
        "TRIG-DAILY-BOOTSTRAP-CHECK"
      ],
      "preconditions": [
        "GitHub App installed",
        "Project exists"
      ],
      "program_sequence": [
        "GH_AUTH_ISSUE_INSTALLATION_TOKEN",
        "GH_FIELDS_DISCOVER",
        "GH_FIELDS_VALIDATE"
      ],
      "writes": [
        "config/github_field_registry.json"
      ],
      "gates_required": [
        "GATE_GH_APP_AUTH_AVAILABLE",
        "GATE_GH_FIELD_REGISTRY_VALID"
      ]
    },
    {
      "phase_id": "PROC-1",
      "name": "PlanProjection",
      "trigger_ids": [
        "TRIG-PLAN-PUSH"
      ],
      "preconditions": [
        "GATE_GH_FIELD_REGISTRY_VALID"
      ],
      "program_sequence": [
        "GH_AUTH_ISSUE_INSTALLATION_TOKEN",
        "GH_PROJECTION_GENERATE",
        "GH_PROJECTION_APPLY"
      ],
      "writes": [
        "config/github_projection_registry.json",
        "config/step_issue_linkage.json",
        "github_issues",
        "github_project_items"
      ],
      "gates_required": [
        "GATE_GH_APP_AUTH_AVAILABLE",
        "GATE_GH_PROJECTION_MANIFEST_VALID"
      ]
    },
    {
      "phase_id": "PROC-2",
      "name": "ExecutionGovernance",
      "trigger_ids": [
        "TRIG-PR-OPENED",
        "TRIG-PR-EDITED",
        "TRIG-PR-REOPENED",
        "TRIG-PR-READY",
        "TRIG-CHECK-COMPLETE",
        "TRIG-PR-CLOSED-MERGED"
      ],
      "workflow_sequence": [
        "branch-handler.yml",
        "project-item-sync.yml",
        "phase_gate_workflows",
        "GH_EVIDENCE_SEAL"
      ],
      "writes": [
        "project_field.Status",
        "project_field.GateStatus",
        "project_field.EvidenceState",
        "issue_comments"
      ],
      "gates_required": [
        "GATE_PR_LINKAGE_VALID",
        "GATE_ALL_REQUIRED_CHECKS_PASS"
      ]
    },
    {
      "phase_id": "PROC-3",
      "name": "PhaseAdvancement",
      "trigger_ids": [
        "TRIG-PR-CLOSED-MERGED",
        "TRIG-CHECK-COMPLETE",
        "TRIG-ISSUE-CLOSED",
        "TRIG-SCHEDULED-RECONCILIATION"
      ],
      "program_sequence": [
        "GH_AUTH_ISSUE_INSTALLATION_TOKEN",
        "GH_PHASE_ADVANCE_EVALUATE"
      ],
      "writes": [
        "reports/phase_advancement_report.json",
        "reports/phase_transition_decision.json",
        "project_field.Phase"
      ],
      "gates_required": [
        "GATE_GH_PHASE_ADVANCEMENT_DECIDED"
      ]
    },
    {
      "phase_id": "PROC-4",
      "name": "Reconciliation",
      "trigger_ids": [
        "TRIG-SCHEDULED-RECONCILIATION",
        "TRIG-ISSUE-OPENED",
        "TRIG-ISSUE-REOPENED",
        "TRIG-ISSUE-CLOSED",
        "TRIG-PR-CLOSED-MERGED",
        "TRIG-PLAN-PUSH"
      ],
      "program_sequence": [
        "GH_AUTH_ISSUE_INSTALLATION_TOKEN",
        "GH_RECONCILE_DRIFT"
      ],
      "writes": [
        "reports/reconciliation_report.json",
        "project_fields",
        "issue_metadata"
      ],
      "gates_required": [
        "GATE_GH_RECONCILIATION_COMPLETE"
      ]
    },
    {
      "phase_id": "PROC-5",
      "name": "RemoteLocalSync",
      "trigger_ids": [
        "TRIG-REMOTE-PUSH"
      ],
      "workflow_sequence": [
        "remote-sync.yml",
        "remote-to-local.yml"
      ],
      "writes": [
        "local_sync_signal",
        "local_repo_state"
      ],
      "gates_required": [
        "GATE_RUNNER_POLICY_VALID"
      ]
    },
    {
      "phase_id": "PROC-6",
      "name": "ScheduledOrchestration",
      "trigger_ids": [
        "TRIG-DAILY-ORCHESTRATOR"
      ],
      "workflow_sequence": [
        "scheduled-orchestrator.yml"
      ],
      "subprocesses": [
        "PROC-4",
        "PROC-3",
        "healthcheck",
        "rollup_reporting"
      ],
      "writes": [
        "daily_reports",
        "healthcheck_reports"
      ],
      "gates_required": [
        "GATE_SYNC_DIRECTION_VALID",
        "GATE_RUNNER_POLICY_VALID"
      ]
    }
  ],
  "event_routes": [
    {
      "route_id": "ROUTE-PLAN-TO-PROJECTION",
      "when": "TRIG-PLAN-PUSH",
      "run": [
        "PROC-1",
        "PROC-4"
      ],
      "expected_result": "GitHub surface converges to latest plan"
    },
    {
      "route_id": "ROUTE-ISSUE-INTAKE",
      "when": "TRIG-ISSUE-OPENED",
      "run": [
        "WF-PROJECT-ITEM-SYNC",
        "PROC-4"
      ],
      "expected_result": "Issue added to project and classified or flagged orphan"
    },
    {
      "route_id": "ROUTE-PR-OPEN",
      "when": "TRIG-PR-OPENED",
      "run": [
        "branch-handler.yml",
        "project-item-sync.yml"
      ],
      "expected_result": "PR linkage validated and status set in progress"
    },
    {
      "route_id": "ROUTE-GATES-PASSED",
      "when": "TRIG-CHECK-COMPLETE",
      "condition": "all_required_checks_pass == true",
      "run": [
        "GH_EVIDENCE_SEAL",
        "PROC-3"
      ],
      "expected_result": "Evidence sealed and phase advancement evaluated"
    },
    {
      "route_id": "ROUTE-PR-MERGED",
      "when": "TRIG-PR-CLOSED-MERGED",
      "run": [
        "project-item-sync.yml",
        "milestone-completion.yml",
        "PROC-3",
        "PROC-4"
      ],
      "expected_result": "Issue closed, milestone updated, phase evaluated, drift reconciled"
    },
    {
      "route_id": "ROUTE-SCHEDULED-SELF-HEAL",
      "when": "TRIG-SCHEDULED-RECONCILIATION",
      "run": [
        "PROC-4",
        "PROC-3"
      ],
      "expected_result": "Missed events healed by level-triggered convergence"
    }
  ],
  "mutation_rules": {
    "idempotency": {
      "strategy": "compare_before_write",
      "safe_mutations": [
        "addProjectV2ItemById",
        "updateProjectV2ItemFieldValue",
        "issue_body_update_if_planhash_changed",
        "comment_post_if_missing_evidence_marker"
      ]
    },
    "rate_limit_budget": {
      "strategy": "header_aware_backoff",
      "sleep_threshold_remaining": 10,
      "retry_policy": {
        "max_retries": 5,
        "backoff": "exponential_with_jitter"
      }
    },
    "loop_prevention": {
      "enabled": true,
      "mechanism": "sync_commit_prefix_and_paths_ignore",
      "applies_to": [
        "remote-sync.yml",
        "remote-to-local.yml"
      ]
    }
  },
  "implementation_targets": {
    "must_exist": [
      ".github/workflows/bootstrap-github-fields.yml",
      ".github/workflows/project-item-sync.yml",
      ".github/workflows/milestone-completion.yml",
      ".github/workflows/plan-projection-sync.yml",
      ".github/workflows/phase-advancement-evaluator.yml",
      ".github/workflows/ssot-drift-reconciliation.yml",
      ".github/workflows/branch-handler.yml",
      ".github/workflows/scheduled-orchestrator.yml",
      "config/github_field_registry.json",
      "config/step_issue_linkage.json",
      "config/github_projection_registry.json",
      "config/github_override_registry.json",
      "policies/runner_policy.yaml",
      "policies/github_sync_governance.yaml",
      "programs/GH_AUTH_ISSUE_INSTALLATION_TOKEN.spec.json",
      "programs/GH_FIELDS_DISCOVER.spec.json",
      "programs/GH_FIELDS_VALIDATE.spec.json",
      "programs/GH_PROJECTION_GENERATE.spec.json",
      "programs/GH_PROJECTION_APPLY.spec.json",
      "programs/GH_RECONCILE_DRIFT.spec.json",
      "programs/GH_PHASE_ADVANCE_EVALUATE.spec.json",
      "schemas/github_field_registry.schema.json",
      "schemas/github_projection_manifest.schema.json",
      "schemas/reconciliation_report.schema.json",
      "schemas/phase_advancement_report.schema.json",
      "schemas/phase_transition_decision.schema.json",
      "schemas/step_issue_linkage.schema.json"
    ]
  },
  "open_questions": [
    {
      "id": "OQ-001",
      "question": "What is the exact canonical plan file glob for projection input in this repository?",
      "default_used_here": [
        "plan/**/*.yml",
        "plan/**/*.yaml",
        "plan/**/*.json",
        "phases/**/*.yml",
        "phases/**/*.yaml",
        "phases/**/*.json"
      ]
    },
    {
      "id": "OQ-002",
      "question": "What is the approval process for adding entries to github_override_registry.json?",
      "default_used_here": "human_via_pull_request_plus_named_owner"
    },
    {
      "id": "OQ-003",
      "question": "Which existing CI workflows are authoritative for required phase gates in this repository?",
      "default_used_here": [
        "quality-gates",
        "registry-integrity",
        "lint",
        "incomplete-scanner"
      ]
    }
  ]
}