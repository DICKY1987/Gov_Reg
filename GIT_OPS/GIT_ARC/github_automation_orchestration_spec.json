  "drift_taxonomy": [
    {
      "class": "Allowed",
      "definition": "Observed difference is permitted by governance."
    },
    {
      "class": "Violation",
      "definition": "Forbidden manual edit or mutation outside ownership model."
    },
    {
      "class": "Orphan",
      "definition": "GitHub issue/PR lacks governing linkage or step identity."
    },
    {
      "class": "Missing",
      "definition": "Required GitHub artifact or field value absent."
    },
    {
      "class": "Override",
      "definition": "Approved intentional divergence recorded in override registry."
    }
  ],
