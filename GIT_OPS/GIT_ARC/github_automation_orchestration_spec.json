  "governing_laws": [
    {
      "id": "LAW-GH-001",
      "name": "APP_FIRST_AUTHENTICATION",
      "statement": "All Project reads/writes must use GitHub App installation tokens unless an explicit PAT exception record exists.",
      "enforcement_gate": "GATE_GH_APP_AUTH_AVAILABLE"
    },
    {
      "id": "LAW-GH-002",
      "name": "NO_INLINE_FIELD_IDS",
      "statement": "No workflow or program may hardcode project node IDs, field IDs, option IDs, or iteration IDs.",
      "enforcement_gate": "GATE_GH_FIELD_REGISTRY_VALID"
    },
    {
      "id": "LAW-GH-003",
      "name": "PHASE_ADVANCEMENT_IS_COMPOSITE",
      "statement": "Only the phase advancement evaluator may mutate the Phase field, and only after composite evaluation and decision artifact generation.",
      "enforcement_gate": "GATE_GH_PHASE_ADVANCEMENT_DECIDED"
    },
    {
      "id": "LAW-RUN-001",
      "name": "PLATFORM_SPLIT_REQUIRED",
      "statement": "Each program and workflow must declare a runner class. Linux-hosted is default for control-plane logic. Windows-specific work must use self-hosted Windows.",
      "enforcement_gate": "GATE_RUNNER_POLICY_VALID"
    },
    {
      "id": "LAW-SYNC-001",
      "name": "PROJECTION_IS_UNIDIRECTIONAL",
      "statement": "GitHub state may not write back into plan-owned fields in the plan SSOT.",
      "enforcement_gate": "GATE_SYNC_DIRECTION_VALID"
    },
    {
      "id": "LAW-WORK-001",
      "name": "NO_ISSUE_WITHOUT_STEP_ID",
      "statement": "Every execution issue must carry StepID mapped in step_issue_linkage.json.",
      "enforcement_gate": "GATE_STEP_LINKAGE_VALID"
    },
    {
      "id": "LAW-WORK-002",
      "name": "NO_PR_WITHOUT_ISSUE",
      "statement": "Every PR must link to at least one governed issue via Closes/Fixes syntax and linkage registry membership.",
      "enforcement_gate": "GATE_PR_LINKAGE_VALID"
    },
    {
      "id": "LAW-WORK-003",
      "name": "NO_MERGE_WITHOUT_GATE",
      "statement": "All required gates for the active phase must pass before merge.",
      "enforcement_gate": "GATE_ALL_REQUIRED_CHECKS_PASS"
    }
  ],
