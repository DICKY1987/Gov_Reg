      "file_type": "python",
      "purpose": "Prevent inline GitHub field IDs from reappearing.",
      "content": "import pathlib\nimport re\nimport sys\n\nPATTERN = re.compile(r\"\\b(PVTF_|PVTSSF_|PVTIF_)\\w+\")\nEXCLUDE = {\n    \"config/github_field_registry.json\"\n}\n\n\ndef main() -> int:\n    violations = []\n    for path in pathlib.Path('.').rglob('*'):\n        if not path.is_file():\n            continue\n        rel = path.as_posix()\n        if rel in EXCLUDE:\n            continue\n        try:\n            text = path.read_text(encoding='utf-8')\n        except Exception:\n            continue\n        if PATTERN.search(text):\n            violations.append(rel)\n    if violations:\n        print(\"INLINE_GITHUB_IDS_FOUND\")\n        for v in violations:\n            print(v)\n        return 1\n    return 0\n\n\nif __name__ == '__main__':\n    raise SystemExit(main())\n",
      "post_write_validation": [
        "python_compile"
      ]
